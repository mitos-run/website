---
// Benchmarks — Fluorescence. Every number is real and reproducible from the
// open-source repo's bench/ scripts. Honest caveats + clearly-labelled vendor
// context (NOT a head-to-head). Keep numbers in sync with BENCHMARKS.md.
import Site from '../layouts/Site.astro';

const GITHUB = 'https://github.com/mitos-run/mitos';
const BENCH = `${GITHUB}/blob/main/bench/husk-activate-latency.sh`;
const METHOD = `${GITHUB}/blob/main/BENCHMARKS.md`;
const HARNESS = `${GITHUB}/issues/15`;

// Headline numbers, measured by us on the reference node.
const stats = [
  { v: '~27 ms', l: 'warm-claim activate', s: 'P50' },
  { v: '~6-16 ms', l: 'snapshot restore', s: 'from memory' },
  { v: '~3 MiB', l: 'marginal per fork', s: 'copy-on-write' },
];

const results = [
  { op: 'Warm-claim activate', p50: '~27 ms', note: 'P50. Snapshot load, fork-correctness handshake, and guest-ready, with the integrity gate enforced.' },
  { op: 'Snapshot restore', p50: '~6 to 16 ms', note: 'Restore a forked microVM from a memory snapshot.' },
  { op: 'Marginal memory per fork', p50: '~3 MiB', note: 'Copy-on-write page sharing. You pay for dirtied pages, not a whole VM.' },
];

const reproduce = `git clone https://github.com/mitos-run/mitos
cd mitos
./bench/husk-activate-latency.sh`;

const caveats = [
  'Numbers are from a bare-metal reference node (Talos on Hetzner). Your hardware will differ.',
  'Verified single-node today. Multi-node fan-out is designed and tracked, not yet measured at N greater than 1.',
  'A warm-claim activate is a fork from a warm parent. It is not the same operation as a cold boot.',
  'mitos is pre-1.0. These numbers move as the engine evolves; the scripts in bench/ are the source of truth.',
];

// Context only. Other vendors' published figures, for different operations, on
// different hardware, with different methodology. NOT a head-to-head benchmark.
const vendorContext = [
  { name: 'mitos', figure: '~27 ms', op: 'warm-claim activate (ours)', ms: 27, own: true },
  { name: 'Daytona', figure: 'sub-90 ms', op: 'create from snapshot', ms: 90 },
  { name: 'E2B', figure: '~150 ms', op: 'sandbox create', ms: 150 },
  { name: 'CodeSandbox', figure: '~495 ms', op: 'memory resume', ms: 495 },
  { name: 'Modal', figure: 'sub-second', op: 'sandbox create', ms: 800 },
  { name: 'Fly Machines', figure: 'under 1 s', op: 'machine start', ms: 1000 },
];
const maxMs = 1000;
---

<Site
  title="mitos benchmarks: reproducible numbers from the engine"
  description="Warm-claim activate P50 about 27 ms, snapshot restore about 6 to 16 ms, about 3 MiB marginal memory per fork. Every number is reproducible from the open-source repo's bench scripts."
>
  <section class="hero container">
    <div class="hero-aura" aria-hidden="true"></div>
    <div class="hero-in reveal">
      <h1>Reproducible numbers. Run them yourself.</h1>
      <p class="lede">
        Every figure here comes from the open-source engine and is
        <strong>reproducible from a script in the repo</strong>. If a number is not in
        <span class="mono hl">bench/</span>, it is not here.
      </p>
      <div class="hero-actions">
        <a class="btn btn-primary btn-lg" href={BENCH} target="_blank" rel="noopener">View the bench script</a>
        <a class="btn btn-ghost btn-lg" href={METHOD} target="_blank" rel="noopener">Methodology</a>
      </div>
    </div>

    <div class="stats reveal">
      {stats.map((s) => (
        <div class="stat">
          <span class="stat-v mono">{s.v}</span>
          <span class="stat-l">{s.l}</span>
          <span class="stat-s mono">{s.s}</span>
        </div>
      ))}
    </div>
  </section>

  <section class="results-sec container">
    <div class="results-head reveal">
      <h2 class="section-title">Measured on the reference node</h2>
      <span class="ref mono">Talos · Hetzner bare metal · single node</span>
    </div>
    <div class="table-wrap reveal">
      <table class="bench-table">
        <thead><tr><th>Operation</th><th>P50</th><th>What it measures</th></tr></thead>
        <tbody>
          {results.map((r) => (
            <tr>
              <td class="op">{r.op}</td>
              <td class="val mono">{r.p50}</td>
              <td class="note">{r.note}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>

  <section class="repro-sec container">
    <div class="repro reveal">
      <div class="repro-copy">
        <h2 class="section-title" style="margin:0 0 12px">Reproduce it</h2>
        <p class="section-lede" style="margin:0">
          Clone the repo and run the script on your own KVM node. You should get the
          same shape of numbers, scaled to your hardware.
        </p>
      </div>
      <div class="terminal repro-term">
        <div class="terminal-bar"><i></i><i></i><i></i>
          <button class="copy-btn mono" data-copy-text={reproduce} aria-label="Copy commands">copy</button>
        </div>
        <pre class="terminal-body">{reproduce}</pre>
      </div>
    </div>
  </section>

  <section class="caveat-sec container">
    <h2 class="section-title reveal">What these numbers do and do not mean</h2>
    <ul class="caveats reveal">
      {caveats.map((c) => <li><span class="dot">·</span>{c}</li>)}
    </ul>
  </section>

  <section class="vendor-sec container">
    <h2 class="section-title reveal">For context, not a head-to-head</h2>
    <p class="section-lede reveal">
      The figures below are other vendors' published numbers, for different operations,
      on different hardware, measured with different methods. They are not measured by
      us. A matched-hardware comparison is <a href={HARNESS} target="_blank" rel="noopener" class="ulink">tracked here</a>.
    </p>
    <div class="vbars reveal">
      {vendorContext.map((v) => (
        <div class={`vbar ${v.own ? 'own' : ''}`}>
          <div class="vbar-label">
            <span class="vbar-name">{v.name}</span>
            <span class="vbar-op">{v.op}</span>
          </div>
          <div class="vbar-track"><span class="vbar-fill" style={`width:${Math.max(2.5, (v.ms / maxMs) * 100)}%`}></span></div>
          <span class="vbar-fig mono">{v.figure}</span>
        </div>
      ))}
    </div>
    <p class="rate-note mono reveal">Bar length scales to each vendor’s published figure. Different operations, hardware, and methods, so read it as rough context, not a benchmark.</p>
  </section>

  <section class="final-cta">
    <div class="container reveal">
      <h2>Fork a microVM and time it yourself.</h2>
      <div class="hero-actions center">
        <a class="btn btn-primary btn-lg" href="/quickstart">Start swarming</a>
        <a class="btn btn-ghost btn-lg" href={GITHUB} target="_blank" rel="noopener">View the repo</a>
      </div>
    </div>
  </section>
</Site>

<style>
  /* HERO */
  .hero { padding-block: 184px 0; position: relative; }
  .hero-aura { position: absolute; top: -60px; left: 4%; width: 680px; max-width: 90vw; height: 520px; z-index: 0; pointer-events: none;
    background: radial-gradient(closest-side, color-mix(in srgb, var(--magenta) 11%, transparent), transparent 72%); opacity: .5; filter: blur(8px); }
  .hero-in { position: relative; z-index: 1; max-width: 720px; }
  .hero h1 { font-size: clamp(46px, 6vw, 76px); line-height: 1.0; letter-spacing: -.035em; font-weight: 400; margin: 0 0 20px; }
  .lede { font-size: 19px; color: var(--ink-2); max-width: 34em; margin: 0 0 28px; line-height: 1.5; }
  .lede .hl { color: var(--cyan); }
  .lede strong { color: var(--ink); font-weight: 500; }
  .hero-actions { display: flex; gap: 12px; flex-wrap: wrap; }
  .hero-actions.center { justify-content: center; }

  .stats { display: flex; gap: 56px; flex-wrap: wrap; margin-top: 56px; position: relative; z-index: 1; }
  .stat { display: flex; flex-direction: column; gap: 4px; }
  .stat-v { font-size: clamp(28px, 4vw, 40px); color: var(--ink); letter-spacing: -.03em; }
  .stat:first-child .stat-v { color: var(--magenta); }
  .stat-l { font-size: 14px; color: var(--ink-2); }
  .stat-s { font-size: 12px; color: var(--ink-3); }

  .section-title { font-size: clamp(28px, 3.6vw, 42px); letter-spacing: var(--track-display); font-weight: 400; margin: 0 0 18px; }
  .section-lede { color: var(--ink-2); font-size: 17px; max-width: 44em; margin: 0 0 48px; }
  .rate-note { margin: 18px 0 0; font-size: 12px; color: var(--ink-3); line-height: 1.5; max-width: 60em; }
  .section-lede .ulink { color: var(--cyan); border-bottom: 1px solid color-mix(in srgb, var(--cyan) 30%, transparent); }
  .section-lede .ulink:hover { border-bottom-color: var(--cyan); }

  /* RESULTS / TABLES */
  .results-sec { padding-block: 100px; }
  .results-head { display: flex; align-items: baseline; justify-content: space-between; gap: 20px; margin-bottom: 44px; flex-wrap: wrap; }
  .results-head .section-title { margin: 0; }
  .ref { font-size: 12px; color: var(--ink-3); }
  .table-wrap { overflow-x: auto; border: 1px solid var(--hairline); border-radius: var(--r-lg); }
  .bench-table { width: 100%; border-collapse: collapse; font-size: 14px; min-width: 620px; }
  .bench-table th, .bench-table td { text-align: left; padding: 16px 18px; border-bottom: 1px solid var(--hairline); vertical-align: top; }
  .bench-table thead th { background: var(--field-1); color: var(--ink-3); font-weight: 500; font-size: 12px; text-transform: uppercase; letter-spacing: .04em; }
  .bench-table tbody tr:last-child td { border-bottom: none; }
  .bench-table tbody tr:hover td { background: rgba(255,255,255,.02); }
  .bench-table .op { color: var(--ink); }
  .bench-table .val { color: var(--cyan); font-size: 15px; white-space: nowrap; }
  .bench-table .note { color: var(--ink-2); font-size: 13px; }
  .vendor-table tr.own td { background: color-mix(in srgb, var(--magenta) 7%, transparent); }
  .vendor-table tr.own .op { color: var(--ink); }
  .vendor-table tr.own .val { color: var(--magenta); }

  /* REPRODUCE */
  .repro-sec { padding-block: 100px; }
  .repro { display: grid; grid-template-columns: 1fr 1.1fr; gap: 44px; align-items: center; }
  .terminal { background: var(--field-1); border: 1px solid var(--hairline); border-radius: var(--r-lg); overflow: hidden; }
  .terminal-bar { display: flex; align-items: center; gap: 6px; padding: 10px 12px 10px 14px; border-bottom: 1px solid var(--hairline); }
  .terminal-bar i { width: 10px; height: 10px; border-radius: 50%; background: var(--hairline-strong); }
  .copy-btn { margin-left: auto; border: 1px solid var(--hairline); border-radius: 6px; padding: 4px 10px; font-size: 11px; color: var(--ink-2); background: transparent; cursor: pointer; transition: color .12s var(--ease), border-color .12s var(--ease); }
  .copy-btn:hover { color: var(--ink); border-color: var(--hairline-strong); }
  .copy-btn.copied { color: var(--green); border-color: var(--green); }
  .terminal-body { padding: 16px 18px; font-family: var(--mono); font-size: 12.5px; line-height: 1.85; color: var(--ink); overflow-x: auto; margin: 0; }

  /* CAVEATS */
  .caveat-sec { padding-block: 100px; }
  .caveats { list-style: none; padding: 0; margin: 44px 0 0; display: flex; flex-direction: column; gap: 14px; max-width: 62em; }
  .caveats li { display: flex; gap: 12px; color: var(--ink-2); font-size: 15px; line-height: 1.55; }
  .caveats .dot { color: var(--magenta); }

  .vendor-sec { padding-block: 100px; }

  /* VENDOR BARS (graphical context) */
  .vbars { display: flex; flex-direction: column; gap: 14px; max-width: 760px; }
  .vbar { display: grid; grid-template-columns: 184px 1fr 90px; gap: 18px; align-items: center; }
  .vbar-label { display: flex; flex-direction: column; gap: 2px; min-width: 0; }
  .vbar-name { font-size: 14px; color: var(--ink-2); }
  .vbar-op { font-size: 11px; color: var(--ink-3); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .vbar-track { height: 26px; background: var(--field-1); border: 1px solid var(--hairline); border-radius: var(--r-sm); overflow: hidden; }
  .vbar-fill { display: block; height: 100%; background: var(--hairline-strong); border-radius: var(--r-sm) 0 0 var(--r-sm); }
  .vbar-fig { font-size: 13px; color: var(--ink-2); text-align: right; white-space: nowrap; }
  .vbar.own .vbar-name { color: var(--ink); font-weight: 500; }
  .vbar.own .vbar-fill { background: linear-gradient(90deg, color-mix(in srgb, var(--magenta) 65%, transparent), var(--magenta)); box-shadow: 0 0 16px color-mix(in srgb, var(--magenta) 45%, transparent); }
  .vbar.own .vbar-fig { color: var(--magenta); }

  /* FINAL CTA */
  .final-cta { text-align: center; padding-block: 104px; }
  .final-cta h2 { font-size: clamp(28px, 4.6vw, 46px); letter-spacing: var(--track-display); margin: 0 0 28px; font-weight: 400; }

  @media (max-width: 900px) {
    .hero { padding-block: 104px 0; }
    .repro { grid-template-columns: 1fr; gap: 24px; }
    .stats { gap: 32px; }
  }
  @media (max-width: 600px) {
    section { padding-block: 64px; }
    .hero { padding-block: 72px 0; }
    .hero h1 { font-size: clamp(30px, 8.4vw, 48px); line-height: 1.06; }
    .section-title { font-size: clamp(24px, 7vw, 32px); }
    .results-sec, .repro-sec, .caveat-sec, .vendor-sec { padding-block: 64px; }
    .stats { gap: 24px 36px; margin-top: 44px; }
    .vbar { grid-template-columns: 104px 1fr 62px; gap: 10px; }
    .vbar-name { font-size: 13px; }
    .vbar-op { font-size: 10px; }
    .vbar-fig { font-size: 12px; }
  }
</style>
