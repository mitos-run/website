---
import Site from '../layouts/Site.astro';

const GITHUB = 'https://github.com/mitos-run/mitos';
const BENCH = `${GITHUB}/blob/main/bench/husk-activate-latency.sh`;
const METHOD = `${GITHUB}/blob/main/BENCHMARKS.md`;
const HARNESS = `${GITHUB}/issues/15`;

// Real, measured numbers from the engine repo. Keep these in sync with the
// repo's BENCHMARKS.md and bench/ scripts. Never publish a number that is not
// reproducible from the repo.
const results = [
  { op: 'Warm-claim activate', p50: '~27 ms', note: 'P50. Snapshot load, fork-correctness handshake, and guest-ready, integrity gate enforced.' },
  { op: 'Snapshot restore', p50: '~6 to 16 ms', note: 'Restore a forked microVM from a memory snapshot.' },
  { op: 'Marginal memory per fork', p50: '~3 MiB', note: 'Copy-on-write page sharing. You pay for dirtied pages, not a whole VM.' },
];

const reproduce = `git clone https://github.com/mitos-run/mitos
cd mitos
./bench/husk-activate-latency.sh`;

const caveats = [
  'Numbers are from a bare-metal reference node (Talos on Hetzner). Your hardware will differ.',
  'Verified single-node today. Multi-node fan-out is designed and tracked, not yet measured at N greater than 1.',
  'A warm-claim activate is a fork from a warm parent. It is not the same operation as a cold boot.',
  'mitos is pre-1.0. These numbers move as the engine evolves; the scripts in bench/ are the source of truth.',
];

// Context only. These are other vendors' published figures, for different
// operations, on different hardware, measured with different methodology. This
// is NOT a head-to-head benchmark. Matched-hardware comparison is tracked.
const vendorContext = [
  { name: 'mitos (measured by us)', figure: '~27 ms', op: 'warm-claim activate, bare-metal reference node', own: true },
  { name: 'Daytona', figure: 'sub-90 ms', op: 'create from snapshot' },
  { name: 'CodeSandbox SDK', figure: '~495 ms', op: 'memory resume' },
  { name: 'E2B', figure: '~150 ms', op: 'sandbox create' },
  { name: 'Modal', figure: 'sub-second', op: 'sandbox create' },
  { name: 'Fly Machines', figure: 'under 1 s', op: 'machine start' },
];
---

<Site
  title="mitos benchmarks: reproducible numbers from the engine"
  description="Warm-claim activate P50 about 27 ms, snapshot restore about 6 to 16 ms, about 3 MiB marginal memory per fork. Every number is reproducible from the open-source repo's bench scripts."
>
  <section class="page-hero container">
    <div class="reveal">
      <p class="eyebrow">Benchmarks</p>
      <h1>Reproducible numbers. Run them yourself.</h1>
      <p class="lede">
        Every figure here comes from the open-source engine and is
        <strong>reproducible from a script in the repo</strong>. If a number is not
        in <span class="mono">bench/</span>, it is not here.
      </p>
      <div class="page-actions">
        <a class="btn btn-primary btn-lg" href={BENCH} target="_blank" rel="noopener">View the bench script ↗</a>
        <a class="btn btn-ghost btn-lg" href={METHOD} target="_blank" rel="noopener">Methodology ↗</a>
      </div>
    </div>
  </section>

  <section class="results-sec container">
    <div class="results-head reveal">
      <h2 class="section-title" style="margin:0">Measured on the reference node</h2>
      <span class="ref mono">Talos · Hetzner bare metal · single node</span>
    </div>
    <div class="table-wrap reveal">
      <table class="bench-table">
        <thead><tr><th>Operation</th><th>P50</th><th>What it measures</th></tr></thead>
        <tbody>
          {results.map((r) => (
            <tr>
              <td class="op">{r.op}</td>
              <td class="val mono">{r.p50}</td>
              <td class="note">{r.note}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>

  <section class="repro-sec container">
    <div class="repro reveal">
      <div class="repro-copy">
        <h2 class="section-title" style="margin:0 0 12px">Reproduce it</h2>
        <p class="section-lede" style="margin:0">
          Clone the repo and run the script on your own KVM node. You should get the
          same shape of numbers, scaled to your hardware.
        </p>
      </div>
      <div class="repro-code">
        <div class="repro-bar">
          <span class="mono">shell</span>
          <button class="copy-btn" data-copy-text={reproduce} aria-label="Copy commands">⧉ copy</button>
        </div>
        <pre class="code-block" style="border-top-left-radius:0;border-top-right-radius:0;border-top:none">{reproduce}</pre>
      </div>
    </div>
  </section>

  <section class="caveat-sec container">
    <h2 class="section-title reveal">What these numbers do and do not mean</h2>
    <ul class="caveats reveal">
      {caveats.map((c) => <li><span class="dot">·</span>{c}</li>)}
    </ul>
  </section>

  <section class="vendor-sec container">
    <h2 class="section-title reveal">For context, not a head-to-head</h2>
    <p class="section-lede reveal">
      The figures below are other vendors' published numbers, for different
      operations, on different hardware, measured with different methods. They are
      not measured by us. A matched-hardware comparison is <a href={HARNESS} target="_blank" rel="noopener" class="ulink">tracked here</a>.
    </p>
    <div class="table-wrap reveal">
      <table class="vendor-table">
        <thead><tr><th>Runtime</th><th>Published figure</th><th>Operation</th></tr></thead>
        <tbody>
          {vendorContext.map((v) => (
            <tr class={v.own ? 'own' : ''}>
              <td class="vn">{v.name}</td>
              <td class="vf mono">{v.figure}</td>
              <td class="vo">{v.op}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>

  <section class="cta-sec">
    <div class="container reveal" style="text-align:center">
      <h2 class="cta-h">Fork a microVM and time it yourself.</h2>
      <div class="page-actions" style="justify-content:center">
        <a class="btn btn-primary btn-lg" href="/quickstart/">Start building</a>
        <a class="btn btn-ghost btn-lg" href={GITHUB} target="_blank" rel="noopener">View the repo ↗</a>
      </div>
    </div>
  </section>
</Site>

<style>
  .results-sec { padding-top: 56px; }
  .results-head { display: flex; align-items: baseline; justify-content: space-between; gap: 20px; margin-bottom: 28px; flex-wrap: wrap; }
  .ref { font-size: 12px; color: var(--dim); }
  .table-wrap { overflow-x: auto; border: 1px solid var(--border); border-radius: 12px; }
  .bench-table, .vendor-table { width: 100%; border-collapse: collapse; font-size: 14px; min-width: 640px; }
  .bench-table th, .bench-table td, .vendor-table th, .vendor-table td { text-align: left; padding: 16px 18px; border-bottom: 1px solid var(--border); }
  .bench-table thead th, .vendor-table thead th { background: var(--surface-2); color: var(--muted); font-weight: 500; font-size: 13px; }
  .bench-table tbody tr:last-child td, .vendor-table tbody tr:last-child td { border-bottom: none; }
  .bench-table .op { font-weight: 500; }
  .bench-table .val { color: #fff; font-size: 16px; }
  .bench-table .note { color: var(--muted); font-size: 13px; }

  .repro-sec { padding-top: 0; }
  .repro { display: grid; grid-template-columns: 1fr 1.1fr; gap: 40px; align-items: center; }
  .repro-bar { display: flex; align-items: center; justify-content: space-between; padding: 9px 12px 9px 14px; border: 1px solid var(--border-2); border-bottom: none; border-radius: 10px 10px 0 0; background: var(--surface-2); }
  .repro-bar span { font-size: 12px; color: var(--muted); }

  .caveat-sec { padding-top: 0; }
  .caveats { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 14px; max-width: 60em; }
  .caveats li { display: flex; gap: 12px; color: var(--muted); font-size: 15px; }
  .caveats .dot { color: var(--text); }

  .vendor-sec { padding-top: 0; }
  .vendor-table .vn { font-weight: 500; }
  .vendor-table .vf { color: var(--text-2); }
  .vendor-table .vo { color: var(--muted); font-size: 13px; }
  .vendor-table tr.own td { background: rgba(255,255,255,.05); }
  .vendor-table tr.own .vf { color: #fff; }
  .ulink { color: var(--text); border-bottom: 1px solid var(--border-strong); }
  .ulink:hover { border-color: #fff; }

  .cta-sec { text-align: center; border-top: 1px solid var(--border); }
  .cta-h { font-size: clamp(28px, 4.5vw, 44px); letter-spacing: -.03em; font-weight: 600; margin: 0 0 26px; }

  @media (max-width: 900px) { .repro { grid-template-columns: 1fr; } }
</style>
