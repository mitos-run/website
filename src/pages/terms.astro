---
// /terms — Terms of Service for the hosted mitos service + mitos.run site.
// Written as if the hosted console is generally available. The contracting
// entity is Paperclip.inc OU (Estonia), matching paperclip.inc/terms; governing
// law is Estonia (no arbitration), with EU/EEA consumer rights preserved. The
// open-source engine is OUT of scope here (it is licensed under Apache 2.0).
// This is a good-faith, plain-language draft modelled on the Paperclip terms and
// AI-sandbox category norms. Review with counsel before relying on it. Keep the
// data-protection + sub-processor claims in sync with /privacy and /cookie-policy.
// Never use em or en dashes in copy.
import Site from '../layouts/Site.astro';

const GITHUB = 'https://github.com/mitos-run/mitos';
const ENTITY = 'Paperclip.inc OÜ';
const LEGAL_EMAIL = 'legal@mitos.run';
const UPDATED = 'June 23, 2026';
const TITLE = 'mitos terms of service: plain language, EU law';
const DESC =
  'The terms for using mitos: forkable microVM sandboxes for agent swarms. Plain language, EU governing law, pay-as-you-go, and we never train on your content.';
---

<Site title={TITLE} description={DESC}>
  <section class="page-hero container">
    <h1>Terms of Service</h1>
    <p class="lede">The agreement for using the hosted mitos service. Plain language, no surprises.</p>
    <p class="updated mono">Last updated: {UPDATED}</p>
