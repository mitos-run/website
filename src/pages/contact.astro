---
// /contact — how to reach the mitos team. Honest channels only (OSS-first; no
// fabricated phone/address). Lifts the E-E-A-T contact signal.
import Site from '../layouts/Site.astro';

const GITHUB = 'https://github.com/mitos-run/mitos';
const TITLE = 'Contact Mitos: GitHub, issues, and security';
const DESC =
  'How to reach the Mitos team: open a GitHub issue, report a security finding, or follow development. Open-source, Apache 2.0.';

const channels = [
  { h: 'GitHub issues', p: 'Bugs, feature requests, and questions about the engine or SDKs. The fastest way to reach us.', cta: 'Open an issue', href: `${GITHUB}/issues` },
  { h: 'Follow development', p: 'Watch the repository for releases and progress, and star it if forking agents is your kind of problem.', cta: 'View the repo', href: GITHUB },
  { h: 'Security', p: 'Report a vulnerability privately. Please do not file public issues for security findings.', cta: 'Read SECURITY.md', href: `${GITHUB}/blob/main/SECURITY.md` },
  { h: 'Early access', p: 'The managed console is not live yet. Run the open-source engine today and watch the repo for hosted availability.', cta: 'Get started', href: '/quickstart' },
];
---

<Site title={TITLE} description={DESC}>
  <section class="hero container">
    <div class="hero-aura" aria-hidden="true"></div>
    <div class="hero-in reveal">
      <h1>Get in touch.</h1>
      <p class="lede">
        Mitos is built in the open. The best way to reach us is on GitHub.
      </p>
      <div class="hero-actions">
        <a class="btn btn-primary btn-lg" href={`${GITHUB}/issues`} target="_blank" rel="noopener">Open an issue</a>
        <a class="btn btn-ghost btn-lg" href={GITHUB} target="_blank" rel="noopener">View the repo</a>
      </div>
    </div>
  </section>

  <section class="container">
    <div class="intro">
    <p>
      We are a small team building infrastructure for AI agent swarms, and we do most of our work
      where the code lives. There is no support ticket maze and no sales gate to get past: if you
      have a question about forking microVMs, an idea for the SDK, or a bug to report, open it on
      GitHub and you will reach the people who actually wrote the engine.
    </p>
    <p>
      Public issues are best for anything others might hit too, since the answer then helps the next
      person. Keep security reports private through the process in SECURITY.md. If you are evaluating
      Mitos for a real workload, the fastest way to get unblocked is usually to run the open-source
      engine from the <a href="/quickstart">quickstart</a> and tell us where it falls short, with a
      concrete repro. We read everything, and we would rather fix the thing you hit than send you a
      canned reply.
    </p>
    </div>
  </section>

  <section class="container">
    <div class="contact-grid">
    {channels.map((c) => (
      <div class="contact-card">
        <h2>{c.h}</h2>
        <p>{c.p}</p>
        <a class="btn btn-ghost" href={c.href} target={c.href.startsWith('http') ? '_blank' : undefined} rel={c.href.startsWith('http') ? 'noopener' : undefined}>{c.cta}</a>
      </div>
    ))}
    </div>
  </section>
</Site>

<style>
  .hero { padding-block: 184px 0; position: relative; }
  .hero-aura { position: absolute; top: -60px; left: 4%; width: 680px; max-width: 90vw; height: 520px; z-index: 0; pointer-events: none;
    background: radial-gradient(closest-side, color-mix(in srgb, var(--magenta) 11%, transparent), transparent 72%);
    opacity: .5; filter: blur(8px); }
  .hero-in { position: relative; z-index: 1; max-width: 720px; }
  .hero h1 { font-size: var(--text-display); line-height: 1.0; letter-spacing: -.035em; font-weight: 400; margin: 0 0 20px; }
  .lede { font-size: var(--text-lede); color: var(--ink-2); max-width: 34em; margin: 0 0 28px; line-height: 1.5; }
  .hero-actions { display: flex; gap: 12px; flex-wrap: wrap; }
  .intro { max-width: 52em; padding-top: 56px; }
  .intro p { color: var(--ink-2); font-size: var(--text-body); line-height: 1.7; margin: 0 0 20px; }
  .intro a { color: var(--cyan); border-bottom: 1px solid color-mix(in srgb, var(--cyan) 30%, transparent); }
  .intro a:hover { border-bottom-color: var(--cyan); }
  .contact-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 16px; padding-top: 40px; padding-bottom: 96px; max-width: 60em; }
  .contact-card { display: flex; flex-direction: column; border: 1px solid var(--hairline); border-radius: var(--r-lg); padding: 28px; }
  .contact-card h2 { font-size: var(--text-title); font-weight: 500; color: var(--ink); margin: 0 0 10px; letter-spacing: -.01em; }
  .contact-card p { color: var(--ink-2); font-size: var(--text-ui); line-height: 1.6; margin: 0 0 20px; }
  .contact-card .btn { margin-top: auto; align-self: flex-start; }
  @media (max-width: 760px) { .hero { padding-block: 104px 0; } .hero h1 { font-size: var(--text-display-sm); line-height: 1.06; } }
  @media (max-width: 700px) { .contact-grid { grid-template-columns: 1fr; } }
</style>
