---
// Pricing — Fluorescence, PAYG-only with a live cost estimator in the hero.
// Model is the engine's real billing shape (decoupled per-second vCPU + RAM,
// storage GiB-hour, metered egress, GPU-second; $100 signup credit; hard spend
// caps). Rates are ILLUSTRATIVE placeholders per the repo's no-published-numbers
// rule — every rate on this page is labelled "illustrative, final at GA".
import Site from '../layouts/Site.astro';

const SIGNUP = '/quickstart/';
const DOCS = '/quickstart/';

// Illustrative rates (mirror engine DefaultPriceList; Modal-magnitude). Shown
// per-hour for humans; the estimator computes per-second.
const rates = [
  { meter: 'Compute · vCPU', rate: '$0.046', unit: '/ vCPU-hour' },
  { meter: 'Memory · RAM', rate: '$0.0058', unit: '/ GiB-hour' },
  { meter: 'Storage', rate: '$0.073', unit: '/ GiB-month' },
  { meter: 'Egress', rate: '$0.09', unit: '/ GiB' },
  { meter: 'GPU', rate: '$2.16', unit: '/ GPU-hour' },
];

const trust = [
  { k: '$100 to start', v: 'Free signup credit, no card. Prepaid top-ups after that.' },
  { k: 'Hard spend caps', v: 'Set a ceiling. A runaway swarm suspends at the cap, not at a surprise invoice.' },
  { k: 'No platform fee', v: 'No seat or subscription floor. You pay for compute, nothing else.' },
  { k: 'No idle charge', v: 'Billing is per-second while running. Paused sandboxes cost nothing to run.' },
];

const faqs = [
  { q: 'How is a swarm billed?', a: 'Per second, with vCPU and memory metered separately. Forks share the parent’s memory copy-on-write, so fanning out mostly adds vCPU-seconds rather than re-paying for the shared base image. Compute scales with how many subagents run.' },
  { q: 'Will I get a surprise bill?', a: 'No. Hard spend caps are on by default: a runaway loop suspends the org at your limit instead of becoming a five-figure invoice. A soft cap alerts you before that.' },
  { q: 'Does forking actually make a swarm cheaper?', a: 'A fork is a live copy-on-write clone of a running microVM, so you skip the cold-boot tax (it resumes in ~27 ms) and don’t re-build the base image for every subagent. The parent’s pages are shared; each fork adds the pages it writes (about 3 MiB right after a fork, more as it diverges). vCPU still scales with how many subagents run, so a swarm’s bill is mostly compute-time, not duplicated memory. The estimator bills each fork its full RAM, so your real memory cost is usually lower.' },
  { q: 'Do I pay for idle sandboxes?', a: 'No. Compute is per-second while running and scales to zero between forks. You are billed for active work, not for waiting.' },
  { q: 'Can I run it myself instead?', a: 'Yes. The engine is open source under Apache 2.0 and free to run on your own Kubernetes cluster. Hosted mitos is for teams who want the fork speed without operating the cluster.' },
];
---

<Site
  title="mitos pricing: pay-as-you-go for agent swarms"
  description="Pay-as-you-go, per-second microVM compute with decoupled vCPU and RAM. Forks share memory copy-on-write so fanning out stays cheap. $100 signup credit, hard spend caps, no platform fee. Illustrative rates; final at GA."
>
  <section class="hero container">
    <div class="hero-aura" aria-hidden="true"></div>

    <div class="hero-copy reveal">
      <h1>Pay by the second.<br />You set the cap.</h1>
      <p class="lede">
        Pay-as-you-go, with <span class="hl">vCPU and memory metered separately</span>.
        No idle charge, no platform fee, and a spend cap you set so a runaway swarm can never surprise you.
      </p>
      <div class="hero-actions">
        <a class="btn btn-primary btn-lg" href={SIGNUP}>Start swarming</a>
        <a class="btn btn-ghost btn-lg" href={DOCS}>Read the docs</a>
      </div>
      <p class="early mono">Hosted mitos is in early access. Rates here are illustrative; final rates land at general availability.</p>
    </div>

    <!-- LIVE COST ESTIMATOR -->
    <div class="calc reveal" id="calc">
      <div class="calc-head">
        <span class="calc-title">Estimate your swarm</span>
        <span class="calc-tag mono">illustrative</span>
      </div>

      <div class="presets" role="group" aria-label="Workload presets">
        <button class="preset" data-preset="solo">Solo agent</button>
        <button class="preset is-on" data-preset="swarm">Eval swarm</button>
        <button class="preset" data-preset="ci">CI fleet</button>
      </div>

      <div class="sliders">
        <label class="slider">
          <span class="slider-top"><span>Sandboxes</span><b id="v-n" class="mono">100</b></span>
          <input type="range" id="s-n" min="1" max="500" step="1" value="100" />
        </label>
        <label class="slider">
          <span class="slider-top"><span>vCPU each</span><b id="v-vcpu" class="mono">1</b></span>
          <input type="range" id="s-vcpu" min="1" max="16" step="1" value="1" />
        </label>
        <label class="slider">
          <span class="slider-top"><span>RAM each</span><b id="v-ram" class="mono">2 GiB</b></span>
          <input type="range" id="s-ram" min="1" max="32" step="1" value="2" />
        </label>
        <label class="slider">
          <span class="slider-top"><span>Minutes each</span><b id="v-min" class="mono">5</b></span>
          <input type="range" id="s-min" min="1" max="120" step="1" value="5" />
        </label>
        <label class="slider">
          <span class="slider-top"><span>Runs / month</span><b id="v-runs" class="mono">50</b></span>
          <input type="range" id="s-runs" min="1" max="1000" step="1" value="50" />
        </label>
      </div>

      <div class="calc-out">
        <div class="calc-total">
          <span class="calc-total-v mono" id="o-total">$0</span>
          <span class="calc-total-l">est. / month</span>
        </div>
        <div class="calc-lines">
          <div class="calc-line"><span>Compute · vCPU</span><b class="mono" id="o-vcpu">$0</b></div>
          <div class="calc-line"><span>Memory · RAM</span><b class="mono" id="o-mem">$0</b></div>
        </div>
        <p class="calc-cow mono">Estimate assumes each fork holds its full RAM. Copy-on-write sharing usually makes memory less, and forks resume in ~27 ms with no cold-boot tax.</p>
        <p class="calc-foot mono">$100 signup credit + hard spend caps. Illustrative rates, final at GA.</p>
      </div>
    </div>
  </section>

  <section class="rates-sec container">
    <h2 class="section-title reveal">One model: pay-as-you-go, per second</h2>
    <p class="section-lede reveal">Decoupled meters, so a CPU-heavy and a RAM-heavy sandbox bill differently. You pay only while a sandbox runs.</p>
    <div class="rate-table reveal">
      {rates.map((r) => (
        <div class="rate-row">
          <span class="rate-meter">{r.meter}</span>
          <span class="rate-val mono">{r.rate}</span>
          <span class="rate-unit mono">{r.unit}</span>
        </div>
      ))}
    </div>
    <p class="rate-note mono reveal">Illustrative rates, final at general availability. Quoted per hour for readability; metered per second.</p>
  </section>

  <section class="trust-sec container">
    <div class="trust-grid">
      {trust.map((t) => (
        <div class="trust reveal">
          <h4>{t.k}</h4>
          <p>{t.v}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="faq-sec container">
    <h2 class="section-title reveal">Questions worth asking</h2>
    <div class="faq-list reveal">
      {faqs.map((f) => (
        <details class="faq-item">
          <summary>{f.q}</summary>
          <p>{f.a}</p>
        </details>
      ))}
    </div>
  </section>

  <section class="final-cta">
    <div class="container reveal">
      <h2>Fan out your first swarm.</h2>
      <div class="hero-actions center">
        <a class="btn btn-primary btn-lg" href={SIGNUP}>Start swarming</a>
        <a class="btn btn-ghost btn-lg" href={DOCS}>Read the docs</a>
      </div>
    </div>
  </section>
</Site>

<style>
  /* HERO (2-col: copy + estimator), matched to landing placement */
  .hero { padding-block: 184px 8px; position: relative; display: grid; grid-template-columns: 1fr minmax(0, 1.02fr); gap: 56px; align-items: start; }
  .hero-aura { position: absolute; top: -60px; left: 2%; width: 640px; max-width: 86vw; height: 520px; z-index: 0; pointer-events: none;
    background: radial-gradient(closest-side, color-mix(in srgb, var(--magenta) 11%, transparent), transparent 72%); opacity: .5; filter: blur(8px); }
  .hero-copy { position: relative; z-index: 1; }
  .hero h1 { font-size: clamp(40px, 4.6vw, 60px); line-height: 1.0; letter-spacing: -.035em; font-weight: 400; margin: 0 0 20px; }
  .lede { font-size: 18px; color: var(--ink-2); max-width: 26em; margin: 0 0 28px; line-height: 1.5; }
  .lede .hl { color: var(--cyan); }
  .hero-actions { display: flex; gap: 12px; flex-wrap: wrap; }
  .hero-actions.center { justify-content: center; }
  .early { margin: 26px 0 0; font-size: 12px; color: var(--ink-3); border-left: 2px solid color-mix(in srgb, var(--magenta) 45%, transparent); padding-left: 14px; max-width: 38em; line-height: 1.55; }

  /* ESTIMATOR */
  .calc { position: relative; z-index: 1; background: var(--field-1); border: 1px solid var(--hairline); border-radius: var(--r-lg); padding: 18px; }
  .calc-head { display: flex; align-items: center; justify-content: space-between; margin-bottom: 12px; }
  .calc-title { font-size: 15px; color: var(--ink); font-weight: 500; }
  .calc-tag { font-size: 10.5px; color: var(--ink-3); border: 1px solid var(--hairline-strong); border-radius: 999px; padding: 3px 9px; text-transform: uppercase; letter-spacing: .05em; }
  .presets { display: flex; gap: 8px; margin-bottom: 14px; }
  .preset { flex: 1; font: inherit; font-size: 12.5px; color: var(--ink-2); background: transparent; border: 1px solid var(--hairline); border-radius: 999px; padding: 7px 6px; cursor: pointer; transition: color .14s var(--ease), border-color .14s var(--ease), background .14s var(--ease); }
  .preset:hover { color: var(--ink); border-color: var(--hairline-strong); }
  .preset.is-on { color: var(--field); background: var(--magenta); border-color: var(--magenta); font-weight: 500; }

  .sliders { display: flex; flex-direction: column; gap: 10px; }
  .slider { display: flex; flex-direction: column; gap: 6px; }
  .slider-top { display: flex; align-items: baseline; justify-content: space-between; font-size: 13px; color: var(--ink-2); }
  .slider-top b { color: var(--ink); font-size: 13px; }
  input[type="range"] { -webkit-appearance: none; appearance: none; width: 100%; height: 4px; border-radius: 999px; background: var(--field-2); outline: none; cursor: pointer; }
  input[type="range"]::-webkit-slider-thumb { -webkit-appearance: none; appearance: none; width: 16px; height: 16px; border-radius: 50%; background: var(--magenta); border: 2px solid var(--field); box-shadow: 0 0 10px color-mix(in srgb, var(--magenta) 55%, transparent); cursor: pointer; }
  input[type="range"]::-moz-range-thumb { width: 14px; height: 14px; border-radius: 50%; background: var(--magenta); border: 2px solid var(--field); cursor: pointer; }

  .calc-out { margin-top: 16px; padding-top: 14px; border-top: 1px solid var(--hairline); }
  .calc-total { display: flex; align-items: baseline; gap: 10px; }
  .calc-total-v { font-size: 36px; color: var(--ink); letter-spacing: -.03em; }
  .calc-total-l { font-size: 13px; color: var(--ink-3); }
  .calc-lines { margin-top: 12px; display: flex; flex-direction: column; gap: 7px; }
  .calc-line { display: flex; align-items: baseline; justify-content: space-between; font-size: 13px; color: var(--ink-2); }
  .calc-line b { color: var(--ink); }
  .calc-cow { margin: 14px 0 0; font-size: 12px; color: var(--ink-3); }
  .calc-cow b { color: var(--cyan); }
  .calc-foot { margin: 10px 0 0; font-size: 11px; color: var(--ink-3); line-height: 1.5; }

  .section-title { font-size: clamp(26px, 3.4vw, 38px); letter-spacing: var(--track-display); font-weight: 400; margin: 0 0 16px; }
  .section-lede { color: var(--ink-2); font-size: 17px; max-width: 42em; margin: 0 0 36px; }

  /* RATE TABLE */
  .rates-sec { padding-block: 80px 0; }
  .rate-table { border-top: 1px solid var(--hairline); max-width: 720px; }
  .rate-row { display: grid; grid-template-columns: 1fr auto auto; gap: 14px; align-items: baseline; padding: 16px 0; border-bottom: 1px solid var(--hairline); }
  .rate-meter { font-size: 15px; color: var(--ink); }
  .rate-val { font-size: 17px; color: var(--magenta); }
  .rate-unit { font-size: 12.5px; color: var(--ink-3); }
  .rate-note { margin: 16px 0 0; font-size: 12px; color: var(--ink-3); }

  /* TRUST */
  .trust-sec { padding-block: 64px 0; }
  .trust-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 0; border-top: 1px solid var(--hairline); }
  .trust { padding: 24px 22px 22px; border-left: 1px solid var(--hairline); }
  .trust:first-child { border-left: none; padding-left: 0; }
  .trust h4 { margin: 0 0 8px; font-size: 15px; font-weight: 500; color: var(--ink); }
  .trust p { margin: 0; color: var(--ink-2); font-size: 13.5px; line-height: 1.55; }

  /* FAQ */
  .faq-sec { padding-block: 72px 0; }
  .faq-list { max-width: 760px; }
  .faq-item summary { list-style: none; cursor: pointer; padding: 16px 0; font-size: 16px; color: var(--ink); display: flex; align-items: center; justify-content: space-between; gap: 16px; transition: color .14s var(--ease); }
  .faq-item summary::-webkit-details-marker { display: none; }
  .faq-item summary::after { content: '+'; color: var(--magenta); font-family: var(--mono); font-size: 18px; }
  .faq-item[open] summary::after { content: '\2212'; }
  .faq-item summary:hover { color: var(--magenta); }
  .faq-item p { margin: 0 0 20px; color: var(--ink-2); font-size: 14.5px; line-height: 1.6; max-width: 60em; }

  /* FINAL CTA */
  .final-cta { text-align: center; border-top: 1px solid var(--hairline); padding-block: 88px; margin-top: 80px; }
  .final-cta h2 { font-size: clamp(30px, 5vw, 50px); letter-spacing: var(--track-display); margin: 0 0 28px; font-weight: 400; }

  @media (max-width: 900px) {
    .hero { padding-block: 104px 8px; grid-template-columns: 1fr; gap: 40px; }
    .hero h1 { font-size: clamp(38px, 8vw, 52px); }
    .trust-grid { grid-template-columns: 1fr 1fr; }
    .trust { border-left: none; padding-left: 0; }
    .trust:nth-child(2) { padding-left: 22px; border-left: 1px solid var(--hairline); }
  }
  @media (max-width: 600px) {
    section { padding-block: 56px; }
    .hero { padding-block: 72px 8px; }
    .hero h1 { font-size: clamp(30px, 8.4vw, 46px); line-height: 1.06; }
    .section-title { font-size: clamp(24px, 7vw, 32px); }
    .rates-sec { padding-block: 56px 0; }
    .trust-grid { grid-template-columns: 1fr; }
    .trust, .trust:nth-child(2) { border-left: none; padding-left: 0; }
    .calc-total-v { font-size: 30px; }
  }
</style>

<script>
  // Illustrative per-second rates (mirror engine DefaultPriceList). Not published facts.
  const VCPU_S = 0.0000128; // $/vCPU-second  (~$0.046/hr)
  const MEM_S = 0.0000016;  // $/GiB-second   (~$0.0058/hr)

  const PRESETS = {
    solo:  { n: 1,   vcpu: 2, ram: 4, min: 15, runs: 200 },
    swarm: { n: 100, vcpu: 1, ram: 2, min: 5,  runs: 50 },
    ci:    { n: 20,  vcpu: 4, ram: 8, min: 10, runs: 300 },
  };

  const $ = (id) => document.getElementById(id);
  const calc = $('calc');
  if (calc) {
    const s = { n: $('s-n'), vcpu: $('s-vcpu'), ram: $('s-ram'), min: $('s-min'), runs: $('s-runs') };
    const fmt = (v) => {
      if (v >= 1000) return '$' + v.toLocaleString('en-US', { maximumFractionDigits: 0 });
      if (v >= 10) return '$' + v.toFixed(0);
      return '$' + v.toFixed(2);
    };
    function render() {
      const n = +s.n.value, vcpu = +s.vcpu.value, ram = +s.ram.value, min = +s.min.value, runs = +s.runs.value;
      const sec = min * 60;
      const vcpuCost = n * vcpu * sec * runs * VCPU_S;
      const memCost = n * ram * sec * runs * MEM_S; // conservative: each fork billed its full RAM
      const total = vcpuCost + memCost;

      $('v-n').textContent = n;
      $('v-vcpu').textContent = vcpu;
      $('v-ram').textContent = ram + ' GiB';
      $('v-min').textContent = min;
      $('v-runs').textContent = runs;

      $('o-total').textContent = fmt(total);
      $('o-vcpu').textContent = fmt(vcpuCost);
      $('o-mem').textContent = fmt(memCost);
    }
    Object.values(s).forEach((el) => el.addEventListener('input', () => {
      document.querySelectorAll('.preset').forEach((p) => p.classList.remove('is-on'));
      render();
    }));
    document.querySelectorAll('.preset').forEach((btn) => btn.addEventListener('click', () => {
      const p = PRESETS[btn.dataset.preset]; if (!p) return;
      s.n.value = p.n; s.vcpu.value = p.vcpu; s.ram.value = p.ram; s.min.value = p.min; s.runs.value = p.runs;
      document.querySelectorAll('.preset').forEach((b) => b.classList.remove('is-on'));
      btn.classList.add('is-on');
      render();
    }));
    render();
  }
</script>
