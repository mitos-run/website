---
// Pricing — Fluorescence. Managed is the product; usage-based, CoW-metered, with
// hard spend caps (the anti-bill-shock guarantee). Hosted is early access, so this
// page explains HOW pricing works rather than quoting final rates. Honest only.
import Site from '../layouts/Site.astro';

const SIGNUP = '/quickstart/';
const DOCS = '/quickstart/';
const GITHUB = 'https://github.com/mitos-run/mitos';

const tiers = [
  {
    name: 'Free',
    tag: 'Start',
    price: 'Credits, no card',
    desc: 'Enough warm compute to fork your first swarms and ship a prototype.',
    features: ['Starter compute credits', 'No credit card', 'Warm pools, millisecond forks', 'Community support'],
    cta: 'Start swarming',
    href: SIGNUP,
    featured: false,
  },
  {
    name: 'Pro',
    tag: 'Usage based',
    price: 'Pay for what you fork',
    desc: 'Per-second compute, metered by copy-on-write so a swarm stays cheap.',
    features: ['Per-second compute, no idle charge', 'CoW metering: pay per dirtied page', 'Hard spend caps on by default', 'Higher concurrency limits', 'Email support'],
    cta: 'Start swarming',
    href: SIGNUP,
    featured: true,
  },
  {
    name: 'Enterprise',
    tag: 'Custom',
    price: "Let's talk",
    desc: 'For teams running swarms at scale with compliance and isolation needs.',
    features: ['Volume pricing', 'SSO, audit logs', 'Run in your own cloud (BYOC)', 'SLA and dedicated support'],
    cta: 'Contact us',
    href: GITHUB,
    featured: false,
  },
];

const meters = [
  { k: 'Compute', v: 'Per second of CPU and memory your sandboxes use. Scale to zero between forks, never pay for idle.' },
  { k: 'Copy-on-write', v: 'A forked subagent costs only the pages it dirties, about 3 MiB. The shared template is counted once, not once per fork.' },
  { k: 'Storage', v: 'Durable workspaces are billed on the bytes you keep. Snapshots ship as deltas, so versions stay cheap.' },
];

const faqs = [
  { q: 'How is a swarm billed?', a: 'You pay for the compute each subagent actually uses, per second. Because forks share memory copy-on-write, fanning out to many subagents adds little beyond the pages each one writes.' },
  { q: 'Will I get a surprise bill?', a: 'No. Hard spend caps are on by default, so a runaway loop stops at your limit instead of becoming a five-figure invoice. Copy-on-write also means you pay for dirtied pages, not whole VMs.' },
  { q: 'Do I pay for idle sandboxes?', a: 'No. Warm pools are managed for you, and compute scales to zero between forks. You are billed for active work, not for waiting.' },
  { q: 'Can I run it myself instead?', a: 'Yes. The engine is open source under Apache 2.0 and free to run on your own Kubernetes cluster. Hosted mitos is for teams who want the fork speed without operating the cluster.' },
  { q: 'What about data residency?', a: 'Enterprise can run mitos in their own cloud (BYOC) so agent code and data stay on their infrastructure.' },
];
---

<Site
  title="mitos pricing: pay for what your swarm changes"
  description="Usage-based pricing for agent swarms. Per-second compute, metered by copy-on-write so fanning out to many subagents stays cheap. Hard spend caps on by default. Hosted mitos is in early access."
>
  <section class="hero container">
    <div class="hero-aura" aria-hidden="true"></div>
    <div class="hero-in reveal">
      <p class="eyebrow mono">Pricing</p>
      <h1>Fork freely. Pay for what changes.</h1>
      <p class="lede">
        Per-second compute, metered by <span class="hl">copy-on-write</span> so a swarm of
        subagents stays cheap to fan out. No idle charges, and hard spend caps on by default.
      </p>
      <div class="hero-actions">
        <a class="btn btn-primary btn-lg" href={SIGNUP}>Start swarming</a>
        <a class="btn btn-ghost btn-lg" href={DOCS}>Read the docs</a>
      </div>
      <p class="early mono">Hosted mitos is in early access. The plans below describe how pricing works; final rates land at general availability.</p>
    </div>
  </section>

  <section class="tiers-sec container">
    <div class="tiers">
      {tiers.map((t) => (
        <article class={`tier reveal ${t.featured ? 'tier-featured' : ''}`}>
          {t.featured && <span class="tier-badge mono">Most popular</span>}
          <div class="tier-head">
            <h3>{t.name}</h3>
            <span class="tier-tag mono">{t.tag}</span>
          </div>
          <p class="tier-price">{t.price}</p>
          <p class="tier-desc">{t.desc}</p>
          <ul class="tier-feats">
            {t.features.map((f) => <li><span class="tick">✓</span>{f}</li>)}
          </ul>
          <a class={`btn ${t.featured ? 'btn-primary' : 'btn-ghost'} tier-cta`} href={t.href}>{t.cta}</a>
        </article>
      ))}
    </div>
  </section>

  <!-- THE MATH: make copy-on-write economics tangible -->
  <section class="math-sec container">
    <h2 class="section-title reveal">The math of forking 100 subagents</h2>
    <p class="section-lede reveal">Copy-on-write means a swarm shares one warm template. You pay for what each fork dirties, not a hundred whole machines.</p>
    <div class="math reveal">
      <div class="math-row">
        <div class="math-label">mitos: one template + 100 forks</div>
        <div class="math-bar"><span class="math-fill mitos" style="width:14%"></span></div>
        <div class="math-num mono">~1.3<span>VMs of memory</span></div>
      </div>
      <div class="math-row">
        <div class="math-label">Whole VMs: 100 copies</div>
        <div class="math-bar"><span class="math-fill plain" style="width:100%"></span></div>
        <div class="math-num mono">100<span>VMs of memory</span></div>
      </div>
      <p class="math-note mono">1 warm template (counted once) + 100 forks × ~3 MiB dirtied each. Illustrative; your real cost depends on what each fork writes.</p>
    </div>
  </section>

  <section class="meter-sec container">
    <h2 class="section-title reveal">How metering works</h2>
    <p class="section-lede reveal">You pay for real work, counted honestly. Three things are metered, nothing else.</p>
    <div class="meter-grid">
      {meters.map((m) => (
        <div class="meter reveal">
          <h4>{m.k}</h4>
          <p>{m.v}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="faq-sec container">
    <h2 class="section-title reveal">Questions worth asking</h2>
    <div class="faq-list reveal">
      {faqs.map((f) => (
        <details class="faq-item">
          <summary>{f.q}</summary>
          <p>{f.a}</p>
        </details>
      ))}
    </div>
  </section>

  <section class="final-cta">
    <div class="container reveal">
      <h2>Fan out your first swarm.</h2>
      <div class="hero-actions center">
        <a class="btn btn-primary btn-lg" href={SIGNUP}>Start swarming</a>
        <a class="btn btn-ghost btn-lg" href={DOCS}>Read the docs</a>
      </div>
    </div>
  </section>
</Site>

<style>
  /* HERO */
  .hero { padding-block: 96px 8px; position: relative; }
  .hero-aura { position: absolute; top: -60px; left: 4%; width: 680px; max-width: 90vw; height: 520px; z-index: 0; pointer-events: none;
    background: radial-gradient(closest-side, color-mix(in srgb, var(--magenta) 11%, transparent), transparent 72%); opacity: .5; filter: blur(8px); }
  .hero-in { position: relative; z-index: 1; max-width: 720px; }
  .eyebrow { color: var(--ink-3); font-size: 12.5px; letter-spacing: .04em; text-transform: uppercase; margin: 0 0 16px; }
  .hero h1 { font-size: clamp(40px, 5.4vw, 64px); line-height: 1.02; letter-spacing: var(--track-display); font-weight: 400; margin: 0 0 20px; }
  .lede { font-size: 19px; color: var(--ink-2); max-width: 32em; margin: 0 0 28px; line-height: 1.5; }
  .lede .hl { color: var(--cyan); }
  .hero-actions { display: flex; gap: 12px; flex-wrap: wrap; }
  .hero-actions.center { justify-content: center; }
  .early { margin: 28px 0 0; font-size: 12.5px; color: var(--ink-3); border-left: 2px solid color-mix(in srgb, var(--magenta) 45%, transparent); padding-left: 14px; max-width: 44em; line-height: 1.55; }

  .section-title { font-size: clamp(26px, 3.4vw, 38px); letter-spacing: var(--track-display); font-weight: 400; margin: 0 0 16px; }
  .section-lede { color: var(--ink-2); font-size: 17px; max-width: 42em; margin: 0 0 40px; }

  /* TIERS */
  .tiers-sec { padding-block: 48px; }
  .tiers { display: grid; grid-template-columns: repeat(3, 1fr); gap: 18px; align-items: stretch; }
  .tier { position: relative; display: flex; flex-direction: column; border: 1px solid var(--hairline); border-radius: var(--r-lg); padding: 28px; background: var(--field-1); transition: border-color .15s var(--ease); }
  .tier:hover { border-color: var(--hairline-strong); }
  .tier-featured { border-color: color-mix(in srgb, var(--magenta) 55%, transparent); background: var(--field-2); }
  .tier-badge { position: absolute; top: -10px; left: 24px; background: var(--magenta); color: var(--field); font-size: 11px; padding: 3px 10px; border-radius: 999px; letter-spacing: .02em; }
  .tier-head { display: flex; align-items: center; justify-content: space-between; margin-bottom: 14px; }
  .tier-head h3 { margin: 0; font-size: 20px; font-weight: 500; }
  .tier-tag { font-size: 11px; color: var(--ink-3); border: 1px solid var(--hairline-strong); border-radius: 999px; padding: 3px 10px; }
  .tier-price { font-size: 20px; font-weight: 500; letter-spacing: -.01em; margin: 0 0 10px; color: var(--ink); }
  .tier-desc { color: var(--ink-2); font-size: 14px; margin: 0 0 20px; line-height: 1.5; }
  .tier-feats { list-style: none; padding: 0; margin: 0 0 24px; display: flex; flex-direction: column; gap: 10px; flex-grow: 1; }
  .tier-feats li { display: flex; gap: 10px; font-size: 14px; color: var(--ink-2); }
  .tier-feats .tick { color: var(--magenta); flex-shrink: 0; }
  .tier-cta { justify-content: center; }

  /* THE MATH */
  .math-sec { padding-block: 64px; }
  .math { max-width: 760px; }
  .math-row { display: grid; grid-template-columns: 1fr; gap: 8px; margin-bottom: 22px; }
  .math-label { font-size: 14px; color: var(--ink-2); }
  .math-bar { height: 30px; background: var(--field-1); border: 1px solid var(--hairline); border-radius: var(--r-sm); overflow: hidden; position: relative; }
  .math-fill { display: block; height: 100%; }
  .math-fill.mitos { background: linear-gradient(90deg, color-mix(in srgb, var(--magenta) 70%, transparent), var(--magenta)); box-shadow: 0 0 18px color-mix(in srgb, var(--magenta) 40%, transparent); }
  .math-fill.plain { background: var(--hairline-strong); }
  .math-num { font-size: 22px; color: var(--ink); display: flex; align-items: baseline; gap: 8px; }
  .math-num span { font-size: 12px; color: var(--ink-3); font-family: var(--sans); }
  .math-note { margin: 14px 0 0; font-size: 12px; color: var(--ink-3); line-height: 1.5; }

  /* METER */
  .meter-sec { padding-block: 0 64px; }
  .meter-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 0; border-top: 1px solid var(--hairline); }
  .meter { padding: 26px 24px 24px; border-left: 1px solid var(--hairline); }
  .meter:first-child { border-left: none; padding-left: 0; }
  .meter h4 { margin: 0 0 8px; font-size: 15px; font-weight: 500; color: var(--ink); }
  .meter p { margin: 0; color: var(--ink-2); font-size: 14px; line-height: 1.55; }

  /* FAQ */
  .faq-sec { padding-block: 0 72px; }
  .faq-list { max-width: 760px; }
  .faq-item summary { list-style: none; cursor: pointer; padding: 16px 0; font-size: 16px; color: var(--ink); display: flex; align-items: center; justify-content: space-between; gap: 16px; transition: color .14s var(--ease); }
  .faq-item summary::-webkit-details-marker { display: none; }
  .faq-item summary::after { content: '+'; color: var(--magenta); font-family: var(--mono); font-size: 18px; }
  .faq-item[open] summary::after { content: '−'; }
  .faq-item summary:hover { color: var(--magenta); }
  .faq-item p { margin: 0 0 20px; color: var(--ink-2); font-size: 14.5px; line-height: 1.6; max-width: 60em; }

  /* FINAL CTA */
  .final-cta { text-align: center; border-top: 1px solid var(--hairline); padding-block: 88px; }
  .final-cta h2 { font-size: clamp(30px, 5vw, 50px); letter-spacing: var(--track-display); margin: 0 0 28px; font-weight: 400; }

  @media (max-width: 900px) {
    .hero { padding-block: 88px 8px; }
    .tiers, .meter-grid { grid-template-columns: 1fr; }
    .meter { border-left: none; padding-left: 0; }
    .meter-grid { border-top: none; }
  }
  @media (max-width: 600px) {
    section { padding-block: 56px; }
    .hero { padding-block: 64px 8px; }
    .hero h1 { font-size: clamp(30px, 8.4vw, 48px); }
    .section-title { font-size: clamp(24px, 7vw, 32px); }
    .math-num { font-size: 19px; }
  }
</style>
