---
// /compare/<slug> — head-to-head comparison pages. Data + rules live in
// src/data/competitors.ts. Positioning per .agents/product-marketing.md: lead
// every beat with mitos, plain/broad language, never praise a rival; the page
// ends on why teams pick mitos, not on "choose them." Targets "mitos vs X" /
// "X alternative" queries. Never use em or en dashes in copy.
import Site from '../../layouts/Site.astro';
import { competitors, getCompetitor } from '../../data/competitors';

export function getStaticPaths() {
  return competitors.map((c) => ({ params: { slug: c.slug } }));
}

const { slug } = Astro.params;
const c = getCompetitor(slug!)!;

const ENGINE = '/docs/quickstart';

const mark = (s: string) => (s === 'y' ? '✓' : s === 'n' ? '✗' : '◐');

const schema = [
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: c.faqs.map((f) => ({
      '@type': 'Question',
      name: f.q,
      acceptedAnswer: { '@type': 'Answer', text: f.a },
    })),
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Mitos', item: 'https://mitos.run' },
      { '@type': 'ListItem', position: 2, name: 'Alternatives', item: 'https://mitos.run/alternatives' },
      { '@type': 'ListItem', position: 3, name: `Mitos vs ${c.name}`, item: `https://mitos.run/compare/${c.slug}` },
    ],
  },
];

const others = competitors.filter((o) => o.slug !== c.slug);
---

<Site title={c.title} description={c.description} schema={schema}>
  <section class="hero container">
    <div class="hero-aura" aria-hidden="true"></div>
    <div class="hero-in reveal">
      <h1>{c.h1}</h1>
      <p class="lede">{c.lede}</p>
      <div class="hero-actions">
        <a class="btn btn-primary btn-lg" href={ENGINE}>Fork a sandbox</a>
        <a class="btn btn-ghost btn-lg" href="/benchmarks">Run the benchmark</a>
      </div>
    </div>
  </section>

  <!-- VERDICT -->
  <section class="container verdict-wrap">
    <div class="verdict reveal">
      <span class="verdict-tag mono">In short</span>
      <p>{c.verdict}</p>
    </div>
  </section>

  <!-- CAPABILITY TABLE -->
  <section class="container cmp-section">
    <h2 class="section-title reveal">Mitos vs {c.name}, capability by capability</h2>
    <p class="section-lede reveal">
      Capabilities from each project's public docs as of June 2026, not a head-to-head benchmark.
      Numbers move; the source of truth is each project's own repo and docs.
    </p>
    <div class="table-wrap reveal">
      <table class="comp-table">
        <thead>
          <tr>
            <th>Capability</th>
            <th class="own">Mitos</th>
            <th>{c.name}</th>
          </tr>
        </thead>
        <tbody>
          {c.rows.map((r) => (
            <tr>
              <td class="feat">{r.feat}</td>
              <td class="own">
                <span class={`mk mk-${r.mitos.s}`}>{mark(r.mitos.s)}</span>
                {r.mitos.t && <span class="ct">{r.mitos.t}</span>}
              </td>
              <td>
                <span class={`mk mk-${r.them.s}`}>{mark(r.them.s)}</span>
                {r.them.t && <span class="ct">{r.them.t}</span>}
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>

  <!-- DIFFERENCES -->
  <section class="container diffs-sec">
    <h2 class="section-title reveal">What sets Mitos apart</h2>
    <div class="diffs">
      {c.sections.map((s) => (
        <div class="diff reveal">
          <h3>{s.h}</h3>
          <p>{s.body}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- WHY MITOS WINS -->
  <section class="container winwrap">
    <div class="winwrap-inner reveal">
      <h2 class="section-title">Why teams pick Mitos over {c.name}</h2>
      <ul class="win-list">
        {c.mitosWins.map((w) => <li>{w}</li>)}
      </ul>
    </div>
  </section>

  <!-- FAQ -->
  <section class="container faq">
    <h2 class="section-title reveal">Mitos vs {c.name}, in brief</h2>
    <div class="faq-list reveal">
      {c.faqs.map((f) => (
        <details class="faq-item">
          <summary>{f.q}</summary>
          <p>{f.a}</p>
        </details>
      ))}
    </div>
  </section>

  <!-- OTHER COMPARISONS -->
  <section class="container more-compare">
    <h2 class="section-title reveal">Other comparisons</h2>
    <div class="more-grid reveal">
      <a class="more-card" href="/alternatives">
        <span class="more-name">All alternatives</span>
        <span class="more-blurb">The full agent-sandbox landscape, side by side.</span>
      </a>
      {others.map((o) => (
        <a class="more-card" href={`/compare/${o.slug}`}>
          <span class="more-name">Mitos vs {o.name}</span>
          <span class="more-blurb">{o.blurb}</span>
        </a>
      ))}
    </div>
  </section>

  <!-- CTA -->
  <section class="final-cta">
    <div class="container reveal">
      <h2>Fork one machine into a swarm.</h2>
      <div class="hero-actions center">
        <a class="btn btn-primary btn-lg" href={ENGINE}>Start in the quickstart</a>
        <a class="btn btn-ghost btn-lg" href="/docs/architecture">Read the architecture</a>
      </div>
    </div>
  </section>
</Site>

<style>
  /* Hero matches /, /pricing, /benchmarks, /alternatives (the big .hero pattern). */
  .hero { padding-block: 184px 0; position: relative; }
  .hero-aura { position: absolute; top: -60px; left: 4%; width: 680px; max-width: 90vw; height: 520px; z-index: 0; pointer-events: none;
    background: radial-gradient(closest-side, color-mix(in srgb, var(--magenta) 11%, transparent), transparent 72%);
    opacity: .5; filter: blur(8px); }
  .hero-in { position: relative; z-index: 1; max-width: 760px; }
  .hero h1 { font-size: var(--text-display); line-height: 1.0; letter-spacing: -.035em; font-weight: 400; margin: 0 0 20px; }
  .lede { font-size: var(--text-lede); color: var(--ink-2); max-width: 36em; margin: 0 0 28px; line-height: 1.5; }
  .hero-actions { display: flex; gap: 12px; flex-wrap: wrap; }
  .hero-actions.center { justify-content: center; }

  .verdict-wrap { padding-top: 44px; }
  .verdict { display: flex; gap: 18px; align-items: flex-start; border: 1px solid var(--hairline); border-left: 2px solid var(--magenta); border-radius: var(--r-md); background: var(--field-1); padding: 22px 24px; max-width: 60em; }
  .verdict-tag { color: var(--magenta); font-size: var(--text-micro); padding-top: 3px; white-space: nowrap; letter-spacing: .04em; text-transform: uppercase; }
  .verdict p { margin: 0; color: var(--ink); font-size: var(--text-body); line-height: 1.6; }

  .cmp-section { padding-top: 88px; }

  /* comparison table (matches the homepage comp-table) */
  .table-wrap { overflow-x: auto; border: 1px solid var(--hairline); border-radius: var(--r-lg); }
  .comp-table { width: 100%; border-collapse: collapse; font-size: var(--text-dense); min-width: 560px; }
  .comp-table th, .comp-table td { text-align: left; padding: 16px 18px; border-bottom: 1px solid var(--hairline); vertical-align: top; }
  .comp-table thead th { background: var(--field-1); color: var(--ink-3); font-weight: 500; font-size: var(--text-micro); text-transform: uppercase; letter-spacing: .04em; }
  .comp-table tbody tr:last-child td { border-bottom: none; }
  .comp-table tbody tr:hover td { background: rgba(255,255,255,.02); }
  .comp-table .feat { color: var(--ink-2); }
  .comp-table th:first-child, .comp-table td:first-child { position: sticky; left: 0; z-index: 1; background: var(--field); }
  .comp-table thead th:first-child { z-index: 2; background: var(--field-1); }
  .comp-table .mk { font-size: var(--text-ui); display: block; line-height: 1.15; }
  .mk-y { color: var(--magenta); } .mk-n { color: var(--ink-3); } .mk-p { color: var(--ink-2); }
  .comp-table .ct { color: var(--ink-3); font-size: var(--text-nano); margin-top: 3px; font-family: var(--mono); display: block; line-height: 1.25; }
  .comp-table .own { color: var(--ink); }
  .comp-table thead th.own { color: var(--magenta); text-align: center; }
  .comp-table thead th:not(:first-child), .comp-table td:not(.feat) { text-align: center; }
  .comp-table .own .mk-y { color: var(--magenta); }

  /* difference prose: rule-divided gallery (like the home use-cases). Each column
     hangs from a shared top rule so they are anchored to one line, not floating. */
  .diffs-sec { padding-top: 88px; }
  .diffs { display: grid; grid-template-columns: repeat(3, 1fr); gap: 0 40px; }
  .diff { border-top: 1px solid var(--hairline); padding-top: 22px; }
  .diff h3 { font-size: var(--text-title); font-weight: 500; color: var(--ink); letter-spacing: -.01em; margin: 0 0 12px; }
  .diff p { color: var(--ink-2); font-size: var(--text-ui); line-height: 1.65; margin: 0; }

  /* why mitos wins */
  .winwrap { padding-top: 88px; }
  .winwrap-inner { border: 1px solid var(--hairline); border-left: 2px solid var(--magenta); border-radius: var(--r-lg); background: var(--field-1); padding: 40px 40px 36px; max-width: 60em; }
  .winwrap-inner .section-title { margin-bottom: 22px; }
  .win-list { margin: 0; padding: 0; list-style: none; display: grid; gap: 14px; }
  .win-list li { color: var(--ink); font-size: var(--text-ui); line-height: 1.55; padding-left: 28px; position: relative; }
  .win-list li::before { content: '\2713'; position: absolute; left: 0; top: 0; color: var(--magenta); font-family: var(--mono); }

  /* faq */
  .faq { padding-top: 88px; }
  .faq-list { max-width: 760px; margin-top: 44px; }
  .faq-item summary { list-style: none; cursor: pointer; padding: 16px 0; font-size: var(--text-body); color: var(--ink); display: flex; align-items: center; justify-content: space-between; gap: 16px; border-bottom: 1px solid var(--hairline); transition: color .14s var(--ease); }
  .faq-item summary:hover { color: var(--magenta); }
  .faq-item summary::-webkit-details-marker { display: none; }
  .faq-item summary::after { content: '+'; color: var(--magenta); font-family: var(--mono); font-size: var(--text-title); }
  .faq-item[open] summary::after { content: '\2212'; }
  .faq-item p { margin: 16px 0 22px; color: var(--ink-2); font-size: var(--text-ui); line-height: 1.6; }

  /* other comparisons */
  .more-compare { padding-top: 88px; }
  .more-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; }
  .more-card { display: flex; flex-direction: column; gap: 6px; border: 1px solid var(--hairline); border-radius: var(--r-md); padding: 20px; transition: border-color .14s var(--ease), transform .14s var(--ease); }
  .more-card:hover { border-color: var(--magenta); transform: translateY(-2px); }
  .more-name { color: var(--ink); font-size: var(--text-ui); font-weight: 500; }
  .more-blurb { color: var(--ink-2); font-size: var(--text-caption); line-height: 1.5; }

  .final-cta { text-align: center; padding-top: 104px; }
  .final-cta h2 { font-size: var(--text-cta); letter-spacing: var(--track-display); margin: 0 0 28px; font-weight: 400; }

  @media (max-width: 900px) {
    .diffs, .more-grid { grid-template-columns: 1fr; }
    .verdict { flex-direction: column; gap: 10px; }
    .winwrap-inner { padding: 28px 24px; }
  }
  @media (max-width: 760px) {
    .hero { padding-block: 104px 0; }
    .hero h1 { font-size: var(--text-display-sm); line-height: 1.06; }
  }
</style>
