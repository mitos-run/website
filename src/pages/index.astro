---
// mitos landing — "Fluorescence" pass. The brand is the product: a living
// microVM divides like a cell into N identical daughters. Black microscope
// field, ONE rationed brand color (Division Cyan #3DDCFF) that appears only on
// the fork primitive, magenta spindle-flash only at the instant of division.
// Signature device: "The Division" — a live, replayable cell-division animation
// (loops, off-screen-paused, reduced-motion-safe), replacing the old
// scroll-gated one-shot fan-out. See
// docs/brand/2026-06-21-brand-and-landing-research.md
// Numbers are real (engine bench/); no fabricated logos or star counts.
import Mark from '../components/Mark.astro';

const GITHUB = 'https://github.com/mitos-run/mitos';
const DOCS = '/quickstart/';
const SIGNUP = '/quickstart/'; // TODO: hosted console signup when live

const canonical = new URL(Astro.url.pathname, Astro.site).href;
const ogImage = new URL('/og.png', Astro.site).href;

const navLinks = [
  { label: 'How it works', href: '#how' },
  { label: 'Benchmarks', href: '/benchmarks/' },
  { label: 'Pricing', href: '/pricing/' },
  { label: 'Docs', href: DOCS },
];

// Hero surfaces: install + copy-to-paste example per language. The fork(8)
// line is the aha. Snippets are runnable against the real API.
const surfaces = [
  {
    id: 'py',
    name: 'Python',
    install: 'pip install mitos',
    code: `from mitos import AgentRun

sb = AgentRun().sandbox("python", ready=True)

# divide a running VM into a swarm. each daughter is its own microVM
swarm = sb.fork(8)
for agent in swarm:
    agent.exec("python subagent.py")`,
  },
  {
    id: 'ts',
    name: 'TypeScript',
    install: 'npm i @mitos/sdk',
    code: `import { AgentRun } from "@mitos/sdk";

const run = new AgentRun();
const sb = await run.sandbox("python", { ready: true });

// divide a running VM into a swarm. each daughter is its own microVM
const swarm = await sb.fork(8);
await Promise.all(swarm.map((a) => a.exec("node subagent.js")));`,
  },
  {
    id: 'cli',
    name: 'CLI',
    install: 'go install mitos.run/mitos/cmd/mitos@latest',
    code: `mitos sandbox create --pool agents --ready
mitos fork vm·0 --count 8 --pool agents
mitos lineage vm·0.3`,
  },
];

const hostedItems = [
  { h: 'No nodes to manage', p: 'Skip the KVM hardware, the snapshot plumbing, and the on-call. Call the API and get a forkable computer.' },
  { h: 'Warm pools, maintained', p: 'Pre-snapshotted pools stay warm so every division lands in milliseconds. We run the autoscaler that keeps them ready.' },
  { h: 'Scale a swarm on demand', p: 'Fan out to thousands of daughters and back to zero. CoW-aware metering bills the honest physical footprint.' },
  { h: 'Production-parity engine', p: 'The hosted service runs the same open-source engine and the same API, so there are no surprises between dev and prod.' },
];

const steps = [
  {
    n: '01',
    title: 'Claim a warm sandbox',
    body: 'Ask for an image, get a running isolated computer in milliseconds, straight from a pre-warmed pool with no cold start.',
    code: `sb = AgentRun().sandbox("python", ready=True)`,
  },
  {
    n: '02',
    title: 'Divide it into a swarm',
    body: 'Copy-on-write fork the running VM into N daughters. Each is an independent, Ready sandbox sharing the warmed genome — only the pages it dirties cost anything.',
    code: `swarm = sb.fork(8)   # ~3 MiB each, not 8 whole VMs`,
  },
  {
    n: '03',
    title: 'Keep the winner',
    body: 'Commit the workspace from the daughter that succeeded. Durable, versioned, forkable state with a traceable lineage.',
    code: `winner.workspace.commit()`,
  },
];

// Capability matrix. Cells: s = 'y' (yes) | 'n' (no) | 'p' (partial), t = short note.
// Honest and capability-based (not a latency head-to-head). Only mitos is 'y' on
// BOTH live fork and open source, which is the whole point.
const compCols = ['mitos', 'E2B', 'Modal', 'Daytona', 'Morph'];
const compRows = [
  { feat: 'Live fork of a running VM', cells: [{ s: 'y' }, { s: 'n' }, { s: 'n' }, { s: 'n' }, { s: 'y' }] },
  { feat: 'microVM isolation per daughter', cells: [{ s: 'y', t: 'KVM' }, { s: 'y' }, { s: 'n', t: 'gVisor' }, { s: 'n', t: 'container' }, { s: 'y' }] },
  { feat: 'Warm pool, no cold start', cells: [{ s: 'y' }, { s: 'y' }, { s: 'y' }, { s: 'y' }, { s: 'y' }] },
  { feat: 'Durable, forkable workspaces', cells: [{ s: 'y' }, { s: 'n' }, { s: 'p', t: 'volumes' }, { s: 'p', t: 'snapshots' }, { s: 'y' }] },
  { feat: 'Open source', cells: [{ s: 'y', t: 'Apache 2.0' }, { s: 'p' }, { s: 'n' }, { s: 'p' }, { s: 'n' }] },
];

// The Division — child node geometry in the SVG viewBox (1000x400). One parent
// cell at (170,200) divides into eight daughters fanned on the right.
const daughters = Array.from({ length: 8 }, (_, i) => ({ i, y: Math.round(48 + i * (304 / 7)) }));
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.ico" sizes="32x32" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon-32.png" type="image/png" sizes="32x32" />
    <link rel="icon" href="/favicon-16.png" type="image/png" sizes="16x16" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#05060A" />
    <title>mitos: one agent divides into a thousand</title>
    <meta
      name="description"
      content="Fork one running microVM into a swarm of isolated subagents — each its own computer, alive in ~27 ms. Open-source engine, fully managed. Live copy-on-write forking for agent swarms."
    />
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="mitos" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content="mitos: one agent divides into a thousand" />
    <meta property="og:description" content="Fork one running microVM into a swarm of isolated subagents — each its own computer, alive in ~27 ms. Open source. Fully managed." />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="mitos logo with the tagline: one agent divides into a thousand" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="mitos: one agent divides into a thousand" />
    <meta name="twitter:description" content="Fork one running microVM into a swarm of isolated subagents — each its own computer, alive in ~27 ms. Open source. Fully managed." />
    <meta name="twitter:image" content={ogImage} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Geist:wght@400;500;600;700&family=Geist+Mono:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <div class="field-glow" aria-hidden="true"></div>

    <!-- NAV -->
    <header class="nav" id="nav">
      <div class="container nav-inner">
        <a class="brand" href="/"><Mark class="brand-mark" /> mitos</a>
        <nav class="nav-links">
          {navLinks.map((l) => <a href={l.href}>{l.label}</a>)}
        </nav>
        <div class="nav-cta">
          <a class="ghost-link" href={GITHUB} target="_blank" rel="noopener">GitHub ↗</a>
          <a class="btn btn-primary" href={SIGNUP}>Start building</a>
        </div>
      </div>
    </header>

    <main>
      <!-- HERO -->
      <section class="hero">
        <div class="container hero-grid">
          <div class="hero-copy reveal">
            <h1>One agent divides<br />into a thousand.</h1>
            <p class="lede">
              Fork one running microVM into a swarm of <strong>isolated subagents</strong>
              — each its own computer, alive in <span class="hl">~27&nbsp;ms</span>.
              Open source. Fully managed.
            </p>
            <div class="hero-actions">
              <a class="btn btn-primary btn-lg" href={SIGNUP}>Start building</a>
              <a class="btn btn-ghost btn-lg" href="/benchmarks/">See the benchmark →</a>
            </div>
            <p class="spec mono">~27&nbsp;ms per fork&nbsp;·&nbsp;~3&nbsp;MiB per daughter (copy-on-write)&nbsp;·&nbsp;fan out to thousands</p>
          </div>

          <div class="hero-code reveal">
            <div class="install">
              <code class="install-cmd mono" id="install-cmd">pip install mitos</code>
              <button class="copy-btn mono" data-copy="install" aria-label="Copy install command">⧉ copy</button>
            </div>
            <div class="card">
              <div class="card-tabs" role="tablist">
                {surfaces.map((s, i) => (
                  <button class={`tab mono ${i === 0 ? 'on' : ''}`} data-tab={s.id} role="tab" aria-selected={i === 0 ? 'true' : 'false'}>{s.name}</button>
                ))}
                <button class="copy-btn card-copy mono" data-copy="code" aria-label="Copy code">⧉ copy</button>
              </div>
              {surfaces.map((s, i) => (
                <pre class={`code-panel ${i === 0 ? "on" : ""}`} data-panel={s.id} data-install={s.install}>{s.code}</pre>
              ))}
            </div>
            <p class="surf-note mono">Python · TypeScript · CLI · <span>+ MCP server</span></p>
          </div>
        </div>
      </section>

      <!-- THE DIVISION (signature centerpiece) -->
      <section class="division-section" id="swarm">
        <div class="container division-head reveal">
          <h2 class="division-h">One cell. <span class="division-h-dim">A living colony of computers.</span></h2>
          <p class="division-lede">
            Copy-on-write fork of a <em>running</em> microVM — memory, processes, and all.
            One machine divides into many daughters, each sharing the warmed genome and
            costing only the pages it dirties. Keep the winner, reap the rest.
          </p>
        </div>

        <div class="division-stage reveal" id="division">
          <svg class="division-svg" viewBox="0 0 1000 400" preserveAspectRatio="xMidYMid meet" role="img" aria-label="One running microVM dividing into eight isolated daughter sandboxes">
            <!-- division paths: parent → each daughter -->
            <g class="d-paths">
              {daughters.map((n) => (
                <path class="d-path" style={`--i:${n.i}`} d={`M214 200 C 470 200 545 ${n.y} 770 ${n.y}`} />
              ))}
            </g>
            <!-- daughters: a sandbox card carrying a cyan cell-core -->
            {daughters.map((n) => (
              <g class="daughter" style={`--i:${n.i}`}>
                <rect x="770" y={n.y - 17} width="150" height="34" rx="9" />
                <circle class="core" cx="789" cy={n.y} r="4.5" />
                <text x="804" y={n.y + 4}>vm·0.{n.i + 1}</text>
              </g>
            ))}
            <!-- spindle: magenta flash at the instant of division -->
            <g class="spindle" aria-hidden="true">
              <line x1="170" y1="150" x2="170" y2="250" />
              <line x1="140" y1="200" x2="200" y2="200" />
            </g>
            <!-- parent cell -->
            <g class="parent">
              <circle class="parent-cell" cx="170" cy="200" r="46" />
              <circle class="parent-core" cx="170" cy="200" r="9" />
              <text x="170" y="205">vm·0</text>
            </g>
          </svg>

          <div class="division-meta mono">
            <button class="run-btn" id="run-fork" type="button" aria-label="Replay the fork">▷ Run <span class="run-call">sb.fork(8)</span></button>
            <span class="dm-out">→ 8 daughters · <span class="dm-ms">~27&nbsp;ms</span> · +3&nbsp;MiB each</span>
          </div>
        </div>

        <div class="container division-foot reveal">
          <div class="division-stats">
            <div><span class="sv mono">~27 ms</span><span class="sl">per division</span></div>
            <div><span class="sv mono">~3 MiB</span><span class="sl">per daughter</span></div>
            <div><span class="sv mono">N-way</span><span class="sl">live fork</span></div>
          </div>
          <p class="division-uses mono">Built for parallel attempts · RL rollouts · test-time scaling · multi-agent eval</p>
        </div>
      </section>

      <!-- WHY HOSTED -->
      <section class="hosted" id="hosted">
        <div class="container hosted-inner reveal">
          <h2 class="section-title">Milliseconds, without operating the cluster</h2>
          <p class="section-lede">
            mitos hosted runs the engine for you. You get the fork speed and the isolation;
            we keep the warm pools full, the nodes healthy, and the fleet scaling. And it’s
            the same Apache-2.0 engine you can <a href={GITHUB} target="_blank" rel="noopener">run yourself</a> — no lock-in.
          </p>
          <div class="hosted-grid">
            {hostedItems.map((it) => (
              <div class="hosted-item"><h4>{it.h}</h4><p>{it.p}</p></div>
            ))}
          </div>
          <a class="btn btn-primary" href={SIGNUP}>Start building</a>
        </div>
      </section>

      <!-- HOW IT WORKS -->
      <section class="how container" id="how">
        <h2 class="section-title reveal">From one computer to a swarm in three calls</h2>
        <div class="steps">
          {steps.map((s) => (
            <div class="step reveal">
              <div class="step-head"><span class="step-n mono">{s.n}</span><h3>{s.title}</h3></div>
              <p>{s.body}</p>
              <pre class="code-block mono">{s.code}</pre>
            </div>
          ))}
        </div>
      </section>

      <!-- COMPARISON -->
      <section class="compare container" id="compare">
        <h2 class="section-title reveal">The one quadrant where mitos is alone</h2>
        <p class="section-lede reveal">
          Runtimes that fork a running VM are closed and hosted-only. Open runtimes don’t
          live-fork. mitos does both — and the engine is honestly open, Apache&nbsp;2.0.
          <span class="muted">Competitor capabilities from their public docs; not a head-to-head benchmark.</span>
        </p>
        <div class="table-wrap reveal">
          <table class="comp-table">
            <thead>
              <tr>
                <th>Capability</th>
                {compCols.map((c, i) => <th class={i === 0 ? 'own' : ''}>{c}</th>)}
              </tr>
            </thead>
            <tbody>
              {compRows.map((r) => (
                <tr>
                  <td class="feat">{r.feat}</td>
                  {r.cells.map((cell, i) => (
                    <td class={i === 0 ? 'own' : ''}>
                      <span class={`mk mk-${cell.s}`}>{cell.s === 'y' ? '✓' : cell.s === 'n' ? '✗' : '◐'}</span>
                      {cell.t && <span class="ct">{cell.t}</span>}
                    </td>
                  ))}
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </section>

      <!-- FINAL CTA -->
      <section class="final-cta">
        <div class="container reveal">
          <h2>Give your agents a swarm of computers.</h2>
          <div class="hero-actions center">
            <a class="btn btn-primary btn-lg" href={SIGNUP}>Start building</a>
            <a class="btn btn-ghost btn-lg" href={DOCS}>Read the docs →</a>
          </div>
        </div>
      </section>
    </main>

    <!-- FOOTER -->
    <footer class="footer">
      <div class="container footer-grid">
        <div class="footer-brand">
          <a class="brand" href="/"><Mark class="brand-mark" /> mitos</a>
          <p class="muted">Live microVM division for agent swarms. One cell becomes a colony.</p>
          <p class="muted mono oss-badge">Open source · Apache 2.0 · <a href={GITHUB} target="_blank" rel="noopener">GitHub ↗</a></p>
        </div>
        <div class="footer-col">
          <h5>Product</h5>
          <a href="#how">How it works</a>
          <a href="/benchmarks/">Benchmarks</a>
          <a href="/pricing/">Pricing</a>
          <a href="#compare">Comparison</a>
        </div>
        <div class="footer-col">
          <h5>Developers</h5>
          <a href={DOCS}>Docs</a>
          <a href="/quickstart/">Quickstart</a>
          <a href="/architecture/">Architecture</a>
          <a href={GITHUB} target="_blank" rel="noopener">GitHub</a>
        </div>
        <div class="footer-col">
          <h5>Company</h5>
          <a href="/blog/">Blog</a>
          <a href={`${GITHUB}/blob/main/SECURITY.md`} target="_blank" rel="noopener">Security</a>
          <a href={`${GITHUB}/blob/main/LICENSE`} target="_blank" rel="noopener">License</a>
        </div>
      </div>
      <div class="container footer-bottom">
        <span class="muted mono">© 2026 mitos · Apache 2.0</span>
      </div>
    </footer>

    <script>
      // Hero code tabs: switch panels + retarget copy + swap install command.
      const tabs = document.querySelectorAll('.tab');
      const panels = document.querySelectorAll('.code-panel');
      const installCmd = document.getElementById('install-cmd');
      tabs.forEach((tab) => {
        tab.addEventListener('click', () => {
          const id = (tab as HTMLElement).dataset.tab;
          tabs.forEach((t) => {
            const on = t === tab;
            t.classList.toggle('on', on);
            t.setAttribute('aria-selected', String(on));
          });
          panels.forEach((p) => {
            const on = (p as HTMLElement).dataset.panel === id;
            p.classList.toggle('on', on);
            if (on && installCmd && (p as HTMLElement).dataset.install) installCmd.textContent = (p as HTMLElement).dataset.install;
          });
        });
      });

      // Copy buttons: install command, or the active code panel.
      document.querySelectorAll('.copy-btn').forEach((btn) => {
        btn.addEventListener('click', async () => {
          let text = '';
          if ((btn as HTMLElement).dataset.copy === 'install') {
            text = (installCmd && installCmd.textContent) || '';
          } else {
            const active = document.querySelector('.code-panel.on');
            text = (active && (active as HTMLElement).innerText) || '';
          }
          try {
            await navigator.clipboard.writeText(text.trim());
            const prev = btn.textContent;
            btn.textContent = '✓ copied';
            btn.classList.add('copied');
            setTimeout(() => { btn.textContent = prev; btn.classList.remove('copied'); }, 1400);
          } catch (e) {}
        });
      });

      const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      const noIO = ('IntersectionObserver' in window) === false;

      // Scroll-reveal.
      const reveals = document.querySelectorAll('.reveal');
      if (reduceMotion || noIO) {
        reveals.forEach((el) => el.classList.add('in'));
      } else {
        const io = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) { entry.target.classList.add('in'); io.unobserve(entry.target); }
          });
        }, { threshold: 0.18, rootMargin: '0px 0px -8% 0px' });
        reveals.forEach((el) => io.observe(el));
      }

      // The Division: a live, replayable cell-division. Resting state shows the
      // completed division (graceful for no-JS / reduced-motion); adding `.run`
      // replays the animation from scratch. Loops only while on-screen.
      const division = document.getElementById('division');
      const runBtn = document.getElementById('run-fork');
      if (division && !reduceMotion) {
        let timer: number | undefined;
        const play = () => {
          division.classList.remove('run');
          void (division as HTMLElement).offsetWidth; // force reflow to restart animation
          division.classList.add('run');
        };
        const start = () => { if (timer) return; play(); timer = window.setInterval(play, 5200); };
        const stop = () => { if (timer) { clearInterval(timer); timer = undefined; } };

        if (noIO) { start(); } else {
          const vio = new IntersectionObserver((entries) => {
            entries.forEach((e) => { e.isIntersecting ? start() : stop(); });
          }, { threshold: 0.35 });
          vio.observe(division);
        }
        if (runBtn) runBtn.addEventListener('click', play);
      }

      // Nav hairline on scroll.
      const nav = document.getElementById('nav');
      const onScroll = () => { if (nav) nav.classList.toggle('scrolled', window.scrollY > 8); };
      onScroll();
      window.addEventListener('scroll', onScroll, { passive: true });
    </script>

    <style is:global>
      :root {
        /* Fluorescence — a microscope field, not a terminal. */
        --bg: #05060A;            /* canvas / void */
        --surface: #0C0E14;       /* raised panels */
        --surface-2: #0F1219;
        --elev: #12151E;
        --border: rgba(232, 235, 242, 0.10);
        --border-strong: rgba(232, 235, 242, 0.20);
        --border-2: rgba(232, 235, 242, 0.14);
        --text: #E8EBF2;          /* ink */
        --text-2: #C7CCD8;
        --muted: #828A9C;
        --dim: #565E70;
        /* rationed brand color — appears ONLY on the fork primitive */
        --cyan: #3DDCFF;          /* Division Cyan (the genome glow) */
        --cyan-soft: rgba(61, 220, 255, 0.16);
        --green: #5BF2A8;         /* live / working */
        --magenta: #FF4D9D;       /* spindle — only at the instant of division */
        --amber: #FFC24B;         /* winner / warning */
        --maxw: 1140px;
        --mono: 'Geist Mono', ui-monospace, SFMono-Regular, Menlo, monospace;
        --sans: 'Geist', system-ui, -apple-system, sans-serif;
      }
      * { box-sizing: border-box; }
      html { scroll-behavior: smooth; scroll-padding-top: 84px; }
      body {
        margin: 0; background: var(--bg); color: var(--text); font-family: var(--sans);
        -webkit-font-smoothing: antialiased; text-rendering: optimizeLegibility;
        line-height: 1.6; overflow-x: hidden;
      }
      ::selection { background: var(--cyan); color: #03121a; }
      .container { max-width: var(--maxw); margin: 0 auto; padding: 0 24px; }
      .mono { font-family: var(--mono); font-variant-numeric: tabular-nums; font-feature-settings: "tnum"; }
      .muted { color: var(--muted); }
      h1, h2, .section-title, .division-h, .final-cta h2 { text-wrap: balance; }
      .lede, .section-lede, .division-lede, .step p, .hosted-item p { text-wrap: pretty; }
      em { font-style: normal; border-bottom: 1px solid var(--border-strong); }
      a { color: inherit; text-decoration: none; }
      .section-lede a, .hosted-inner a:not(.btn) { color: var(--text-2); border-bottom: 1px solid var(--cyan-soft); transition: border-color .15s ease; }
      .section-lede a:hover, .hosted-inner a:not(.btn):hover { border-bottom-color: var(--cyan); }
      :focus-visible { outline: 2px solid var(--cyan); outline-offset: 3px; border-radius: 4px; }
      .hl { color: var(--cyan); }

      /* faint cyan field glow — the slide under the microscope */
      .field-glow {
        position: fixed; top: -340px; left: 50%; transform: translateX(-50%);
        width: 1200px; height: 820px; z-index: 0; pointer-events: none;
        background:
          radial-gradient(ellipse 60% 60% at 50% 38%, rgba(61,220,255,.07), transparent 70%),
          radial-gradient(ellipse 70% 50% at 50% 30%, rgba(255,255,255,.03), transparent 72%);
      }
      main, .nav, .footer { position: relative; z-index: 1; }

      /* reveal */
      .reveal { opacity: 0; transform: translateY(16px); transition: opacity .6s cubic-bezier(.2,.6,.2,1), transform .6s cubic-bezier(.2,.6,.2,1); }
      .reveal.in { opacity: 1; transform: none; }
      .steps .step:nth-child(2) { transition-delay: .08s; }
      .steps .step:nth-child(3) { transition-delay: .16s; }
      @media (prefers-reduced-motion: reduce) { .reveal { opacity: 1; transform: none; transition: none; } }

      /* buttons */
      .btn { display: inline-flex; align-items: center; gap: 8px; font-weight: 500; font-size: 14px; border-radius: 8px; padding: 9px 17px; border: 1px solid transparent; cursor: pointer; transition: background .14s ease, border-color .14s ease, transform .14s ease, box-shadow .14s ease; white-space: nowrap; }
      .btn-lg { padding: 12px 22px; font-size: 15px; }
      .btn-primary { background: var(--text); color: #04060c; border-color: var(--text); font-weight: 600; }
      .btn-primary:hover { transform: translateY(-1px); box-shadow: 0 10px 30px -10px rgba(61,220,255,.45); }
      .btn-ghost { background: transparent; color: var(--text); border-color: var(--border-strong); }
      .btn-ghost:hover { border-color: var(--cyan); background: rgba(61,220,255,.06); transform: translateY(-1px); }
      .btn:active { transform: translateY(0); }

      /* nav */
      .nav { position: sticky; top: 0; z-index: 50; backdrop-filter: blur(12px); background: rgba(5,6,10,.6); border-bottom: 1px solid transparent; transition: border-color .2s ease; }
      .nav.scrolled { border-bottom-color: var(--border); }
      .nav-inner { display: flex; align-items: center; gap: 32px; height: 64px; }
      .brand { font-weight: 600; font-size: 17px; letter-spacing: -.02em; display: inline-flex; align-items: center; gap: 8px; }
      .brand-mark { height: 18px; width: auto; }
      .nav-links { display: flex; gap: 26px; margin-right: auto; }
      .nav-links a { color: var(--muted); font-size: 14px; }
      .nav-links a:hover { color: var(--text); }
      .nav-cta { display: flex; align-items: center; gap: 16px; }
      .ghost-link { color: var(--muted); font-size: 14px; }
      .ghost-link:hover { color: var(--text); }

      /* hero */
      .hero { padding: 96px 0 88px; }
      .hero-grid { display: grid; grid-template-columns: 1fr 1.06fr; gap: 48px; align-items: center; }
      h1 { font-size: clamp(40px, 5.6vw, 66px); line-height: 1.0; letter-spacing: -.04em; font-weight: 600; margin: 0 0 22px; }
      .lede { font-size: 18px; color: var(--muted); max-width: 25em; margin: 0 0 28px; line-height: 1.5; }
      .lede strong { color: var(--text); font-weight: 600; }
      .hero-actions { display: flex; gap: 12px; margin-bottom: 22px; flex-wrap: wrap; }
      .hero-actions.center { justify-content: center; }
      .spec { font-size: 12.5px; color: var(--dim); margin: 0; letter-spacing: -.01em; }

      /* hero code */
      .install { display: flex; align-items: center; justify-content: space-between; gap: 12px; border: 1px solid var(--border-2); border-radius: 9px; padding: 10px 12px 10px 14px; margin-bottom: 12px; background: var(--elev); }
      .install-cmd { font-size: 13px; color: #f2f2f2; overflow-x: auto; white-space: nowrap; }
      .install-cmd::before { content: '$ '; color: var(--cyan); }
      .copy-btn { border: 1px solid var(--border); border-radius: 6px; padding: 5px 10px; font-size: 11px; color: var(--muted); background: transparent; cursor: pointer; transition: all .12s ease; white-space: nowrap; }
      .copy-btn:hover { color: var(--text); border-color: var(--border-strong); }
      .copy-btn.copied { color: var(--cyan); border-color: var(--cyan); }
      .card { background: var(--elev); border: 1px solid var(--border-2); border-radius: 11px; overflow: hidden; box-shadow: 0 30px 80px -32px rgba(0,0,0,.9); }
      .card-tabs { display: flex; align-items: center; border-bottom: 1px solid var(--border-2); background: #181c26; }
      .tab { font-size: 12px; color: #9aa2b4; padding: 11px 16px; border: none; border-bottom: 1px solid transparent; background: transparent; cursor: pointer; transition: color .12s ease; }
      .tab:hover { color: var(--text-2); }
      .tab.on { color: var(--text); border-bottom-color: var(--cyan); }
      .card-copy { margin-left: auto; margin-right: 8px; }
      .code-panel { display: none; margin: 0; padding: 18px 20px; min-height: 200px; font-family: var(--mono); font-size: 12.5px; line-height: 1.85; color: #dfe3ec; overflow-x: auto; }
      .code-panel.on { display: block; }
      .surf-note { text-align: center; color: var(--dim); font-size: 12px; margin: 14px 0 0; }
      .surf-note span { color: var(--muted); }

      /* sections */
      section { padding: 100px 0; }
      .section-title { font-size: clamp(28px, 4vw, 40px); letter-spacing: -.03em; font-weight: 600; margin: 0 0 18px; }
      .section-lede { color: var(--muted); font-size: 17px; max-width: 46em; margin: 0 0 48px; }
      .section-lede .muted { display: block; font-size: 13px; margin-top: 8px; color: var(--dim); }

      /* THE DIVISION — cinematic centerpiece */
      .division-section { border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); padding: 100px 0 92px; }
      .division-head { text-align: center; max-width: 720px; margin: 0 auto; }
      .division-h { font-size: clamp(30px,4.4vw,46px); letter-spacing: -.03em; margin: 0 0 16px; line-height: 1.05; font-weight: 600; text-wrap: balance; }
      .division-h-dim { color: var(--muted); }
      .division-lede { color: var(--muted); font-size: 17px; margin: 0 auto; max-width: 40em; text-wrap: pretty; }
      .division-lede em { border-bottom: 1px solid var(--border-strong); }

      .division-stage { position: relative; max-width: 940px; margin: 44px auto 10px; padding: 0 24px; }
      .division-svg { width: 100%; height: auto; display: block; overflow: visible; }

      /* division paths */
      .d-path { fill: none; stroke: rgba(61,220,255,.28); stroke-width: 1.25; stroke-dasharray: 1400; stroke-dashoffset: 0; }
      .division-stage.run .d-path { stroke-dashoffset: 1400; animation: dDraw .75s cubic-bezier(.4,0,.2,1) forwards; animation-delay: calc(.06s * var(--i) + .28s); }
      @keyframes dDraw { to { stroke-dashoffset: 0; } }

      /* daughters (resting = visible) */
      .daughter rect { fill: #0a0d14; stroke: rgba(232,235,242,.18); }
      .daughter .core { fill: var(--cyan); filter: drop-shadow(0 0 4px rgba(61,220,255,.9)); }
      .daughter text { fill: #c2c8d6; font-family: var(--mono); font-size: 13px; }
      .division-stage.run .daughter { opacity: 0; transform: scale(.4); transform-box: fill-box; transform-origin: 789px center; animation: dPop .5s cubic-bezier(.2,.8,.2,1) forwards; animation-delay: calc(.06s * var(--i) + .62s); }
      @keyframes dPop { to { opacity: 1; transform: scale(1); } }

      /* spindle: magenta, flashes only at the split */
      .spindle line { stroke: var(--magenta); stroke-width: 2; stroke-linecap: round; opacity: 0; }
      .division-stage.run .spindle line { animation: dFlash .5s ease-out forwards; animation-delay: .3s; }
      @keyframes dFlash { 0% { opacity: 0; } 35% { opacity: .9; filter: drop-shadow(0 0 6px var(--magenta)); } 100% { opacity: 0; } }

      /* parent cell */
      .parent-cell { fill: rgba(61,220,255,.05); stroke: var(--cyan); stroke-width: 2; }
      .parent-core { fill: var(--cyan); filter: drop-shadow(0 0 7px rgba(61,220,255,.8)); }
      .parent text { fill: var(--text); font-family: var(--mono); font-size: 14px; text-anchor: middle; }
      .division-stage.run .parent-cell { animation: dCharge 1s ease-out; }
      @keyframes dCharge { 0% { transform: scale(1); } 22% { transform: scale(1.06); filter: drop-shadow(0 0 10px rgba(61,220,255,.6)); } 100% { transform: scale(1); } }
      .parent-cell { transform-box: fill-box; transform-origin: center; }

      .division-meta { position: absolute; left: 50%; bottom: -6px; transform: translateX(-50%); display: flex; gap: 12px; align-items: center; font-size: 12.5px; color: var(--muted); flex-wrap: wrap; justify-content: center; }
      .run-btn { font-family: var(--mono); font-size: 12.5px; color: var(--text); background: rgba(61,220,255,.06); border: 1px solid var(--cyan-soft); border-radius: 7px; padding: 6px 12px; cursor: pointer; transition: border-color .14s ease, background .14s ease; }
      .run-btn:hover { border-color: var(--cyan); background: rgba(61,220,255,.12); }
      .run-call { color: var(--cyan); }
      .dm-out { color: var(--dim); }
      .dm-ms { color: var(--cyan); }

      .division-foot { text-align: center; margin-top: 34px; }
      .division-stats { display: inline-flex; gap: 48px; margin-bottom: 18px; }
      .division-stats .sv { display: block; font-size: 24px; color: var(--text); letter-spacing: -.03em; }
      .division-stats .sl { font-size: 12px; color: var(--muted); }
      .division-uses { color: var(--dim); font-size: 12px; margin: 0; }
      @media (prefers-reduced-motion: reduce) {
        .division-stage .d-path { stroke-dashoffset: 0; }
        .division-stage .daughter { opacity: 1; transform: none; }
        .division-stage .spindle line { opacity: 0; }
      }

      /* hosted */
      .hosted { background: var(--surface); border-bottom: 1px solid var(--border); }
      .hosted-inner { text-align: center; }
      .hosted-inner .section-lede { margin-left: auto; margin-right: auto; }
      .hosted-grid { display: grid; grid-template-columns: repeat(4,1fr); gap: 16px; margin: 0 0 36px; text-align: left; }
      .hosted-item { padding: 22px; border: 1px solid var(--border); border-radius: 10px; background: var(--bg); transition: border-color .15s ease; }
      .hosted-item h4 { margin: 0 0 8px; font-size: 15px; font-weight: 600; }
      .hosted-item p { margin: 0; color: var(--muted); font-size: 14px; }

      /* how */
      .steps { display: grid; grid-template-columns: repeat(3,1fr); gap: 16px; }
      .step { background: var(--surface); border: 1px solid var(--border); border-radius: 12px; padding: 24px; transition: border-color .15s ease; }
      .step:hover, .hosted-item:hover { border-color: var(--border-strong); }
      .step-head { display: flex; align-items: center; gap: 12px; margin-bottom: 10px; }
      .step-n { color: var(--cyan); font-size: 13px; }
      .step h3 { margin: 0; font-size: 17px; font-weight: 600; }
      .step p { color: var(--muted); font-size: 14px; margin: 0 0 16px; }
      .code-block { background: var(--bg); border: 1px solid var(--border); border-radius: 8px; padding: 14px; font-size: 12px; line-height: 1.6; color: var(--text-2); overflow-x: auto; margin: 0; white-space: pre-wrap; }

      /* comparison */
      .table-wrap { overflow-x: auto; border: 1px solid var(--border); border-radius: 12px; }
      .comp-table { width: 100%; border-collapse: collapse; font-size: 14px; min-width: 740px; }
      .comp-table th, .comp-table td { text-align: left; padding: 14px 18px; border-bottom: 1px solid var(--border); }
      .comp-table thead th { background: var(--surface-2); color: var(--muted); font-weight: 500; font-size: 13px; }
      .comp-table tbody tr:last-child td { border-bottom: none; }
      .comp-table tbody tr { transition: background .12s ease; }
      .comp-table tbody tr:hover td { background: rgba(232,235,242,.025); }
      .comp-table .feat { font-weight: 500; }
      .comp-table .mk { font-size: 15px; }
      .mk-y { color: var(--cyan); } .mk-n { color: var(--dim); } .mk-p { color: var(--muted); }
      .comp-table .ct { color: var(--muted); font-size: 12px; margin-left: 8px; font-family: var(--mono); }
      .comp-table .own { background: rgba(61,220,255,.06); color: var(--text); font-weight: 500; border-left: 1px solid var(--cyan-soft); border-right: 1px solid var(--cyan-soft); }
      .comp-table .own .mk-y { color: var(--cyan); }
      .comp-table thead th.own { color: var(--cyan); text-align: center; }
      .comp-table thead th:not(:first-child), .comp-table td:not(.feat) { text-align: center; }

      /* final cta */
      .final-cta { text-align: center; border-top: 1px solid var(--border); }
      .final-cta h2 { font-size: clamp(30px,5vw,52px); letter-spacing: -.04em; margin: 0 0 28px; font-weight: 600; }

      /* footer */
      .footer { border-top: 1px solid var(--border); padding: 56px 0 32px; background: var(--surface); }
      .footer-grid { display: grid; grid-template-columns: 2fr 1fr 1fr 1fr; gap: 32px; }
      .footer-brand .brand { margin-bottom: 12px; }
      .footer-brand p { font-size: 14px; max-width: 26em; margin: 0 0 8px; }
      .oss-badge { font-size: 12px; } .oss-badge a:hover { color: var(--cyan); }
      .footer-col h5 { margin: 0 0 14px; font-size: 13px; font-weight: 500; color: var(--muted); }
      .footer-col a { display: block; color: var(--muted); font-size: 14px; padding: 4px 0; }
      .footer-col a:hover { color: var(--text); }
      .footer-bottom { margin-top: 40px; padding-top: 24px; border-top: 1px solid var(--border); font-size: 13px; }

      /* responsive */
      @media (max-width: 900px) {
        .hero-grid { grid-template-columns: 1fr; }
        .hosted-grid, .steps { grid-template-columns: 1fr; }
        .footer-grid { grid-template-columns: 1fr 1fr; }
        .nav-links { display: none; }
        .division-stats { gap: 28px; }
      }
      @media (max-width: 560px) {
        .division-stats { gap: 20px; }
        .division-stats .sv { font-size: 20px; }
        .division-meta { font-size: 11px; }
      }
    </style>
  </body>
</html>
