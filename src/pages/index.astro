---
// mitos landing — "Fluorescence" (dark, magenta-dominant, microscope field).
// Position: the live-fork / swarm primitive (Act 3 of the category), not "a
// secure sandbox". Managed is the product; Apache-2.0 is the no-lock-in trust
// signal. Numbers are real (engine bench/). No fabricated logos/testimonials.
// Never use em or en dashes in copy. See docs/brand/brand-book.md and
// docs/superpowers/plans/2026-06-22-fluorescence-page-rebuild.md.
import Site from '../layouts/Site.astro';
import Division from '../components/Division.astro';
import pythonIcon from '../assets/lang/python.svg?raw';
import tsIcon from '../assets/lang/typescript.svg?raw';
import cliIcon from '../assets/lang/cli.svg?raw';
import mcpIcon from '../assets/lang/mcp.svg?raw';
const langIcons: Record<string, string> = { py: pythonIcon, ts: tsIcon, cli: cliIcon, mcp: mcpIcon };

const GITHUB = 'https://github.com/mitos-run/mitos';
const DOCS = '/quickstart/';
const SIGNUP = '/quickstart/'; // hosted console not live yet; OSS run-now path

const TITLE = 'mitos: one agent divides into a thousand';
const DESC =
  'Fork a running microVM into hundreds of isolated subagents in about 27ms, roughly 3 MiB each. Live state, not a disk snapshot. Managed, and Apache-2.0 so you are never locked in.';

// Hero surfaces: install + copy-to-paste example per language. The fork(8) line
// is the aha. Snippets are runnable against the real API.
const surfaces = [
  {
    id: 'py',
    name: 'Python',
    install: 'pip install mitos',
    code: `from mitos import AgentRun

sb = AgentRun().sandbox("python", ready=True)

# fork a running VM into a swarm. each fork is its own microVM
swarm = sb.fork(8)
for agent in swarm:
    agent.exec("python subagent.py")`,
  },
  {
    id: 'ts',
    name: 'TypeScript',
    install: 'npm i @mitos/sdk',
    code: `import { AgentRun } from "@mitos/sdk";

const run = new AgentRun();
const sb = await run.sandbox("python", { ready: true });

// divide a running VM into a swarm. each daughter is its own microVM
const swarm = await sb.fork(8);
await Promise.all(swarm.map((a) => a.exec("node subagent.js")));`,
  },
  {
    id: 'cli',
    name: 'CLI',
    install: 'go install mitos.run/mitos/cmd/mitos@latest',
    code: `mitos sandbox create --pool agents --ready
mitos fork vm-0 --count 8 --pool agents
mitos lineage vm-0.3`,
  },
  {
    id: 'mcp',
    name: 'MCP',
    install: 'go install mitos.run/mitos/cmd/mitos-mcp@latest',
    code: `{
  "mcpServers": {
    "mitos": {
      "command": "mitos-mcp"
    }
  }
}`,
  },
];

// Minimal syntax highlighter for the hero snippets. Maps to our signal colors;
// the fork primitive is highlighted in magenta (the brand signature in code).
function hl(code: string): string {
  const esc = (s: string) => s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
  const KW = /\b(from|import|const|await|new|for|def|return|in)\b/g;
  return code.split('\n').map((line) => {
    let codePart = line, comPart = '';
    const m = line.match(/#|\/\//);
    if (m) { const i = line.indexOf(m[0]); codePart = line.slice(0, i); comPart = line.slice(i); }
    const h = esc(codePart)
      .replace(/(['"])(.*?)\1/g, '<span class="c-str">$1$2$1</span>')
      .replace(/\bfork\b/g, '<span class="c-fork">fork</span>')
      .replace(KW, '<span class="c-kw">$1</span>');
    return comPart ? h + '<span class="c-com">' + esc(comPart) + '</span>' : h;
  }).join('\n');
}

const useCases = [
  { h: 'Best-of-N attempts', p: 'Run N attempts in parallel, commit the one that worked, drop the rest.' },
  { h: 'RL rollouts and fan-out', p: 'Thousands of parallel environments from one warm template, then back to zero.' },
  { h: 'Tree search', p: 'Branch a running agent mid-thought for MCTS. Parallel beats serial.' },
  { h: 'Multi-agent evals', p: 'Every agent its own computer, isolated from the rest.' },
  { h: 'Untrusted code', p: 'Model-written code in a microVM with its own kernel.' },
];

const steps = [
  { n: '01', title: 'Grab a warm sandbox', body: 'Ask for an image and get a running, isolated computer back in milliseconds. The pool was already warm, so there is no cold start.', code: `sb = AgentRun().sandbox("python", ready=True)` },
  { n: '02', title: 'Fork it', body: 'Copy the running VM as many times as you want. Each fork is its own microVM and shares the parent in memory, so eight cost about 3 MiB each.', code: `swarm = sb.fork(8)   # ~3 MiB each, not 8 whole VMs` },
  { n: '03', title: 'Keep what worked', body: 'Commit the sandbox that succeeded and throw the rest away. The result is versioned, and you can fork it again whenever you want.', code: `winner.workspace.commit()` },
];

const hostedItems = [
  { h: 'No cluster to run', p: 'No KVM hosts to patch, no snapshot storage to babysit, no 3am page.' },
  { h: 'Pools stay warm', p: 'Pre-forked VMs stay hot, so forks land in milliseconds, one or five hundred.' },
  { h: 'Open source is your exit', p: 'Same Apache-2.0 engine you can run yourself. No rewrite, no lock-in.' },
  { h: 'Dev and prod match', p: 'Same engine, same API, laptop to production.' },
];

// Honest, capability-based comparison from public docs (not a head-to-head
// benchmark). s = 'y' yes | 'n' no | 'p' partial; t = short note. Only mitos is
// 'y' on live-fork AND microVM AND Apache-2.0 AND managed at once.
const compCols = ['mitos', 'E2B', 'Modal', 'Daytona', 'Morph'];
const compRows = [
  { feat: 'Live fork of a running VM (memory + processes)', cells: [{ s: 'y' }, { s: 'n', t: 'snapshot' }, { s: 'n', t: 'snapshot' }, { s: 'p', t: 'filesystem' }, { s: 'p', t: 'snapshot' }] },
  { feat: 'Published marginal cost per daughter', cells: [{ s: 'y', t: '~3 MiB' }, { s: 'n' }, { s: 'n' }, { s: 'n' }, { s: 'n' }] },
  { feat: 'microVM isolation (own kernel)', cells: [{ s: 'y', t: 'KVM' }, { s: 'y' }, { s: 'n', t: 'gVisor' }, { s: 'n', t: 'gVisor' }, { s: 'p', t: 'undisclosed' }] },
  { feat: 'Open source', cells: [{ s: 'y', t: 'Apache 2.0' }, { s: 'y', t: 'Apache 2.0' }, { s: 'n' }, { s: 'p', t: 'AGPL' }, { s: 'n' }] },
  { feat: 'Fully managed cloud', cells: [{ s: 'y' }, { s: 'y' }, { s: 'y' }, { s: 'y' }, { s: 'y' }] },
];

const faqs = [
  { q: 'Is the fork really unique?', a: 'No, and we will not pretend it is. A few others can branch a VM. No one else combines a live fork of running memory at about 27ms and 3 MiB per daughter, microVM-isolated, managed, and Apache-2.0.' },
  { q: 'How many forks can I run at once?', a: 'Hundreds to thousands from one warm parent. They share its memory, so cost grows with what each one writes, not with the count.' },
  { q: 'Can I run it myself?', a: 'Yes. The engine is Apache-2.0 on GitHub, the same code the managed service runs.' },
  { q: 'How are subagents isolated?', a: 'Each fork is a Firecracker microVM with its own kernel, isolated by KVM.' },
  { q: 'Will I get a surprise bill?', a: 'Hard spend caps are on by default, and copy-on-write means you pay for dirtied pages, not whole VMs.' },
  { q: 'Which languages and SDKs?', a: 'Python, TypeScript, and a CLI, plus an MCP server. The sandbox runs any Linux workload.' },
];

// The Division — one parent at (170,200) divides into eight daughters fanned on
// the right of a 1000x400 viewBox. Fluorescence: magenta parent (the fork
// primitive), cyan daughters (the genome), additive glow.
const daughters = Array.from({ length: 8 }, (_, i) => ({ i, y: Math.round(48 + i * (304 / 7)) }));
---

<Site title={TITLE} description={DESC}>
  <!-- HERO -->
  <section class="hero">
    <div class="hero-aura" aria-hidden="true"></div>
    <div class="container hero-grid">
      <div class="hero-copy reveal">
        <h1>Run agent swarms</h1>
        <p class="lede">Isolated, forkable computers for your agents.</p>
        <div class="hero-actions">
          <a class="btn btn-primary btn-lg" href={SIGNUP}>Start swarming</a>
          <a class="btn btn-ghost btn-lg" href="/benchmarks/">See the benchmark</a>
        </div>
      </div>

      <div class="hero-code reveal">
        <div class="install">
          <code class="install-cmd mono" id="install-cmd">pip install mitos</code>
          <button class="hcopy mono" data-copy="install" type="button" aria-label="Copy install command">⧉ copy</button>
        </div>
        <div class="card">
          <div class="card-tabs" role="tablist">
            {surfaces.map((s, i) => (
              <button class={`tab mono ${i === 0 ? 'on' : ''}`} data-tab={s.id} role="tab" aria-selected={i === 0 ? 'true' : 'false'}><span class="tab-ic" set:html={langIcons[s.id]} />{s.name}</button>
            ))}
            <button class="hcopy card-copy mono" data-copy="code" type="button" aria-label="Copy code">⧉ copy</button>
          </div>
          {surfaces.map((s, i) => (
            <pre class={`code-panel mono ${i === 0 ? 'on' : ''}`} data-panel={s.id} data-install={s.install} set:html={hl(s.code)} />
          ))}
        </div>
      </div>
    </div>

    <!-- TRUST STRIP -->
    <div class="container trust reveal">
      <span>Apache&nbsp;2.0</span>
      <span>~27&nbsp;ms per fork</span>
      <span>~3&nbsp;MiB per subagent</span>
      <span>Firecracker microVMs</span>
    </div>
  </section>

  <!-- THE DIVISION -->
  <section class="division-section" id="swarm">
    <div class="container division-head reveal">
      <h2 class="division-h">Most sandboxes cold-boot or restore a snapshot.<br /><span class="division-h-hl">mitos forks the running machine.</span></h2>
      <p class="division-lede">
        A fork copies the <em>live</em> VM, memory and all, not just the disk. Daughters share
        the parent's pages and pay only for what they change: about 3&nbsp;MiB each, not eight
        whole VMs.
      </p>
    </div>

    <div class="division-stage reveal" id="division">
      <svg class="fan-svg" viewBox="0 0 1000 400" preserveAspectRatio="xMidYMid meet" role="img" aria-label="One running microVM cell dividing into eight isolated subagent cells">
        <defs>
          <radialGradient id="fgenome" cx="50%" cy="46%" r="55%">
            <stop offset="0%" stop-color="#ffffff" />
            <stop offset="44%" stop-color="#bfeeff" />
            <stop offset="100%" stop-color="#3DDCFF" stop-opacity="0" />
          </radialGradient>
          <radialGradient id="fmem" cx="50%" cy="50%" r="50%">
            <stop offset="32%" stop-color="#FF45C8" stop-opacity="0" />
            <stop offset="64%" stop-color="#FF45C8" stop-opacity=".6" />
            <stop offset="84%" stop-color="#FF45C8" stop-opacity=".2" />
            <stop offset="100%" stop-color="#FF45C8" stop-opacity="0" />
          </radialGradient>
        </defs>
        <g class="d-paths">
          {daughters.map((n) => (
            <path class="d-path" style={`--i:${n.i}`} d={`M210 200 C 470 200 545 ${n.y} 798 ${n.y}`} />
          ))}
        </g>
        {daughters.map((n) => (
          <g class="fan-daughter" style={`--i:${n.i}`}>
            <circle class="cell-mem" cx="822" cy={n.y} r="23" fill="url(#fmem)" />
            <circle class="cell-core" cx="822" cy={n.y} r="10.5" fill="url(#fgenome)" />
            <text x="855" y={n.y + 4}>vm-0.{n.i + 1}</text>
          </g>
        ))}
        <g class="fan-parent">
          <circle class="cell-mem parent-mem" cx="150" cy="200" r="52" fill="url(#fmem)" />
          <circle class="cell-core" cx="150" cy="200" r="27" fill="url(#fgenome)" />
          <text x="150" y="276" class="parent-label">vm-0</text>
        </g>
      </svg>

      <div class="division-meta mono">
        <button class="run-btn" id="run-fork" type="button" aria-label="Replay the fork">▷ Run <span class="run-call">sb.fork(8)</span></button>
        <span class="dm-out">→ 8 subagents · <span class="dm-hl">~27&nbsp;ms</span> · +3&nbsp;MiB each</span>
      </div>
    </div>

    <div class="container division-foot reveal">
      <div class="division-stats">
        <div><span class="sv mono">~27 ms</span><span class="sl">per fork</span></div>
        <div><span class="sv mono">~3 MiB</span><span class="sl">per subagent</span></div>
        <div><span class="sv mono">N-way</span><span class="sl">live fork</span></div>
      </div>
    </div>
  </section>

  <!-- USE CASES -->
  <section class="usecases container" id="usecases">
    <h2 class="section-title reveal">Built for the work that needs many of them</h2>
    <p class="section-lede reveal">One warm machine becomes a swarm, then collapses back to zero.</p>
    <div class="uc-grid">
      {useCases.map((u) => (
        <div class="uc-item reveal"><h4>{u.h}</h4><p>{u.p}</p></div>
      ))}
    </div>
  </section>

  <!-- HOW IT WORKS -->
  <section class="how container" id="how">
    <h2 class="section-title reveal">From one computer to a swarm in three calls</h2>
    <div class="steps">
      {steps.map((s) => (
        <div class="step reveal">
          <div class="step-head"><span class="step-n mono">{s.n}</span><h3>{s.title}</h3></div>
          <p>{s.body}</p>
          <pre class="code-block mono">{s.code}</pre>
        </div>
      ))}
    </div>
  </section>

  <!-- MANAGED + OSS -->
  <section class="hosted" id="hosted">
    <div class="container hosted-inner reveal">
      <h2 class="section-title">We run the cluster. You call the API.</h2>
      <p class="section-lede">
        We keep the bare-metal fleet alive so you don't. Same engine you can
        <a href={GITHUB} target="_blank" rel="noopener">run yourself</a>, so you are never locked in.
      </p>
      <div class="hosted-grid">
        {hostedItems.map((it) => (
          <div class="hosted-item"><h4>{it.h}</h4><p>{it.p}</p></div>
        ))}
      </div>
      <a class="btn btn-primary" href={SIGNUP}>Start swarming</a>
    </div>
  </section>

  <!-- COMPARISON -->
  <section class="compare container" id="compare">
    <h2 class="section-title reveal">Live fork, microVM isolation, and actually open</h2>
    <p class="section-lede reveal">
      Plenty of runtimes do one of these. mitos does all of them.
      <span class="muted">Capabilities from each project's public docs, not a head-to-head benchmark.</span>
    </p>
    <div class="table-wrap reveal">
      <table class="comp-table">
        <thead>
          <tr>
            <th>Capability</th>
            {compCols.map((c, i) => <th class={i === 0 ? 'own' : ''}>{c}</th>)}
          </tr>
        </thead>
        <tbody>
          {compRows.map((r) => (
            <tr>
              <td class="feat">{r.feat}</td>
              {r.cells.map((cell, i) => (
                <td class={i === 0 ? 'own' : ''}>
                  <span class={`mk mk-${cell.s}`}>{cell.s === 'y' ? '✓' : cell.s === 'n' ? '✗' : '◐'}</span>
                  {cell.t && <span class="ct">{cell.t}</span>}
                </td>
              ))}
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>

  <!-- SECURITY -->
  <section class="security container" id="security">
    <div class="sec-inner reveal">
      <h2 class="section-title">Every fork is a real microVM, not a shared kernel</h2>
      <p class="section-lede">
        Each subagent runs in its own Firecracker microVM with its own kernel. A prompt injection
        that turns into a shell stays inside one disposable fork, not your host and not the other agents.
      </p>
    </div>
  </section>

  <!-- ECONOMICS -->
  <section class="econ container" id="pricing-teaser">
    <div class="econ-inner reveal">
      <h2 class="section-title">Pay for divergence, not duplication</h2>
      <p class="section-lede">
        Forks share the parent's memory until they write, so you pay for the pages they dirty, about
        3&nbsp;MiB each, not whole VMs. Hard spend caps are on by default.
      </p>
      <a class="btn btn-ghost" href="/pricing/">See pricing</a>
    </div>
  </section>

  <!-- FAQ -->
  <section class="faq container" id="faq">
    <h2 class="section-title reveal">Questions worth asking</h2>
    <div class="faq-list reveal">
      {faqs.map((f) => (
        <details class="faq-item">
          <summary>{f.q}</summary>
          <p>{f.a}</p>
        </details>
      ))}
    </div>
  </section>

  <!-- FINAL CTA -->
  <section class="final-cta">
    <div class="container reveal">
      <h2>Give your agents a swarm of computers.</h2>
      <div class="hero-actions center">
        <a class="btn btn-primary btn-lg" href={SIGNUP}>Start swarming</a>
        <a class="btn btn-ghost btn-lg" href={DOCS}>Read the docs</a>
      </div>
    </div>
  </section>
</Site>

<script>
  // Hero code tabs: switch panels + swap install command.
  const tabs = document.querySelectorAll('.tab');
  const panels = document.querySelectorAll('.code-panel');
  const installCmd = document.getElementById('install-cmd');
  tabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      const id = (tab as HTMLElement).dataset.tab;
      tabs.forEach((t) => { const on = t === tab; t.classList.toggle('on', on); t.setAttribute('aria-selected', String(on)); });
      panels.forEach((p) => {
        const on = (p as HTMLElement).dataset.panel === id;
        p.classList.toggle('on', on);
        if (on && installCmd && (p as HTMLElement).dataset.install) installCmd.textContent = (p as HTMLElement).dataset.install;
      });
    });
  });

  // Hero copy buttons (install command or active code panel).
  document.querySelectorAll('.hcopy').forEach((btn) => {
    btn.addEventListener('click', async () => {
      let text = '';
      if ((btn as HTMLElement).dataset.copy === 'install') text = (installCmd && installCmd.textContent) || '';
      else { const active = document.querySelector('.code-panel.on'); text = (active && (active as HTMLElement).innerText) || ''; }
      try {
        await navigator.clipboard.writeText(text.trim());
        const prev = btn.textContent; btn.textContent = '✓ copied'; btn.classList.add('copied');
        setTimeout(() => { btn.textContent = prev; btn.classList.remove('copied'); }, 1400);
      } catch (e) {}
    });
  });

  // The Division fan-out: replay on first view and on button click.
  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const noIO = ('IntersectionObserver' in window) === false;
  const division = document.getElementById('division');
  const runBtn = document.getElementById('run-fork');
  if (division && !reduceMotion) {
    const play = () => { division.classList.remove('run'); void (division as HTMLElement).offsetWidth; division.classList.add('run'); };
    if (noIO) { play(); } else {
      const vio = new IntersectionObserver((entries) => { entries.forEach((e) => { if (e.isIntersecting) { play(); vio.unobserve(division); } }); }, { threshold: 0.4 });
      vio.observe(division);
    }
    if (runBtn) runBtn.addEventListener('click', play);
  }
</script>

<style>
  /* HERO */
  .hero { padding: 128px 0 32px; position: relative; }
  /* faint diegetic ambient: the specimen under illumination. Restrained (~5%). */
  .hero-aura { position: absolute; top: -80px; left: 6%; width: 800px; height: 640px; z-index: 0; pointer-events: none;
    background: radial-gradient(closest-side, color-mix(in srgb, var(--magenta) 12%, transparent), transparent 72%);
    opacity: .5; filter: blur(8px); }
  .hero-grid { display: grid; grid-template-columns: 1fr minmax(0, 1.08fr); gap: 60px; align-items: center; position: relative; z-index: 1; }
  /* min-width:0 lets the code column shrink so different snippet widths scroll
     inside a fixed-width card instead of resizing the whole column. */
  .hero-code { min-width: 0; }
  .hero-code .card, .hero-code .install { min-width: 0; max-width: 100%; }
  .hero-copy h1 { font-size: clamp(46px, 6vw, 76px); line-height: 1.0; letter-spacing: -.035em; font-weight: 400; margin: 0 0 20px; }
  .lede { font-size: 19px; color: var(--ink-2); max-width: 24em; margin: 0 0 28px; line-height: 1.5; }
  .lede strong { color: var(--ink); font-weight: 500; }
  .lede .hl { color: var(--cyan); font-weight: 500; }
  .lede-sub { font-size: 15px; color: var(--ink-2); margin: 0 0 28px; }
  .lede-sub strong { color: var(--magenta); font-weight: 500; }
  .hero-actions { display: flex; gap: 12px; margin-bottom: 22px; flex-wrap: wrap; }
  .hero-actions.center { justify-content: center; }
  .spec { font-size: 12.5px; color: var(--ink-3); margin: 0; letter-spacing: -.01em; }

  /* hero code card */
  .install { display: flex; align-items: center; justify-content: space-between; gap: 12px; border: 1px solid var(--hairline); border-radius: var(--r-md); padding: 10px 12px 10px 14px; margin-bottom: 12px; background: var(--field-1); }
  .install-cmd { font-size: 13px; color: var(--ink); overflow-x: auto; white-space: nowrap; min-width: 0; flex: 1; }
  .install-cmd::before { content: '$ '; color: var(--magenta); }
  .hcopy { border: 1px solid var(--hairline); border-radius: 6px; padding: 5px 10px; font-size: 11px; color: var(--ink-2); background: transparent; cursor: pointer; transition: color .12s var(--ease), border-color .12s var(--ease); white-space: nowrap; }
  .hcopy:hover { color: var(--ink); border-color: var(--hairline-strong); }
  .hcopy.copied { color: var(--green); border-color: var(--green); }
  .card { background: var(--field-1); border: 1px solid var(--hairline); border-radius: var(--r-lg); overflow: hidden; }
  .card-tabs { display: flex; align-items: center; border-bottom: 1px solid var(--hairline); background: var(--field-2); }
  .tab { display: inline-flex; align-items: center; gap: 7px; font-size: 13px; color: var(--ink-2); padding: 13px 18px; border: none; border-bottom: 1.5px solid transparent; background: transparent; cursor: pointer; transition: color .12s var(--ease), border-color .12s var(--ease); }
  .tab:hover { color: var(--ink); }
  .tab.on { color: var(--ink); border-bottom-color: var(--magenta); }
  .tab-ic { display: inline-flex; }
  .tab-ic :global(svg) { width: 15px; height: 15px; display: block; }
  .card-copy { margin-left: auto; margin-right: 8px; align-self: center; }
  /* fixed height so switching tabs never resizes the card */
  .code-panel { display: none; margin: 0; padding: 18px 20px; height: 232px; box-sizing: border-box; font-size: 12.5px; line-height: 1.85; color: var(--ink); overflow: auto; }
  .code-panel.on { display: block; }
  .code-panel :global(.c-com) { color: var(--ink-3); }
  .code-panel :global(.c-str) { color: var(--green); }
  .code-panel :global(.c-kw) { color: color-mix(in srgb, var(--cyan) 72%, var(--ink)); }
  .code-panel :global(.c-fork) { color: var(--magenta); font-weight: 600; }
  .surf-note { text-align: center; color: var(--ink-3); font-size: 12px; margin: 14px 0 0; }
  .surf-note span { color: var(--ink-2); }

  /* TRUST STRIP */
