---
// Consent-gated, EU-hosted PostHog analytics (GDPR / ePrivacy).
// PostHog is NOT loaded and NO network request is made until the visitor clicks
// "Accept". Then: EU data residency, anonymous (person_profiles identified_only,
// and we never identify), session replay with all inputs masked, Do-Not-Track
// respected. The
// choice persists in localStorage; visitors can change it via the footer
// "Cookie settings" link (window.openCookieSettings).
//
// KEEP IN SYNC when touching this:
//  - /privacy (src/pages/privacy.astro) must disclose PostHog + analytics cookies.
//  - The Cloudflare CSP must allow eu(.|-assets.)i.posthog.com (see docs/ops/).
//  - In the PostHog project: enable "Discard client IP data" and keep the EU region.
import '../styles/tokens.css'; // ensure brand tokens exist on Starlight docs pages too
const PH_KEY = 'phc_t6anh6zShJNraN2w2BjYjUWpXaDns9bHHwcrMoJHGHsp';
const PH_HOST = 'https://eu.i.posthog.com';
---
<div id="cookie-banner" class="cookie-banner" role="dialog" aria-label="Analytics consent" aria-live="polite" hidden>
  <p class="cookie-eyebrow mono"><span class="cookie-dot" aria-hidden="true"></span>analytics</p>
  <p class="cookie-text">
    Help us make Mitos better. We use PostHog (EU-hosted) to see how the site is really used,
    including session replays with every input masked. Opt-in only, IPs discarded, never sold, and
    nothing loads until you accept. <a href="/privacy">Details</a>.
  </p>
  <div class="cookie-actions">
    <button id="cookie-decline" class="cookie-btn" type="button">Decline</button>
    <button id="cookie-accept" class="cookie-btn cookie-btn-accept" type="button">Accept</button>
  </div>
</div>

<script is:inline define:vars={{ PH_KEY, PH_HOST }}>
  (function () {
    var KEY = 'mitos-analytics-consent';

    function loadPostHog() {
      if (window.__phLoaded) return;
      window.__phLoaded = true;
      !function(t,e){var o,n,p,r;e.__SV||(window.posthog=e,e._i=[],e.init=function(i,s,a){function g(t,e){var o=e.split(".");2==o.length&&(t=t[o[0]],e=o[1]),t[e]=function(){t.push([e].concat(Array.prototype.slice.call(arguments,0)))}}(p=t.createElement("script")).type="text/javascript",p.async=!0,p.src=s.api_host.replace(".i.posthog.com","-assets.i.posthog.com")+"/static/array.js",(r=t.getElementsByTagName("script")[0]).parentNode.insertBefore(p,r);var u=e;for(void 0!==a?u=e[a]=[]:a="posthog",u.people=u.people||[],u.toString=function(t){var e="posthog";return"posthog"!==a&&(e+="."+a),t||(e+=" (stub)"),e},u.people.toString=function(){return u.toString(1)+".people (stub)"},o="init capture register register_once register_for_session unregister opt_out_capturing has_opted_out_capturing opt_in_capturing reset isFeatureEnabled getFeatureFlag getFeatureFlagPayload reloadFeatureFlags group identify setPersonProperties setPersonPropertiesForFlags resetPersonPropertiesForFlags setGroupPropertiesForFlags resetGroupPropertiesForFlags resetGroups onFeatureFlags addFeatureFlagsHandler onSessionId getSurveys getActiveMatchingSurveys renderSurvey canRenderSurvey getNextSurveyStep".split(" "),n=0;n<o.length;n++)g(u,o[n]);e._i.push([i,s,a])},e.__SV=1)}(document,window.posthog||[]);
      posthog.init(PH_KEY, {
        api_host: PH_HOST,
        defaults: '2026-01-30',
        person_profiles: 'identified_only', // no profiles for anonymous visitors
        capture_pageview: true,
        autocapture: true,
        // Session replay ON but privacy-masked: every form input is masked so no
        // typed values are ever captured (the site has no login/PII fields anyway).
        disable_session_recording: false,
        session_recording: { maskAllInputs: true },
        respect_dnt: true,                   // honor Do-Not-Track
        persistence: 'localStorage+cookie'
      });
    }

    var banner;
    function setBanner(open) { if (!banner) banner = document.getElementById('cookie-banner'); if (banner) banner.hidden = !open; }

    // Let visitors reopen the choice (wire a footer link to this).
    window.openCookieSettings = function () { setBanner(true); };

    function read() { try { return localStorage.getItem(KEY); } catch (e) { return null; } }
    function write(v) { try { localStorage.setItem(KEY, v); } catch (e) {} }

    var choice = read();
    if (choice === 'granted') loadPostHog();

    document.addEventListener('DOMContentLoaded', function () {
      if (read() === null) setBanner(true);
      var accept = document.getElementById('cookie-accept');
      var decline = document.getElementById('cookie-decline');
      if (accept) accept.addEventListener('click', function () { write('granted'); loadPostHog(); setBanner(false); });
      if (decline) decline.addEventListener('click', function () { write('denied'); if (window.posthog && window.posthog.opt_out_capturing) window.posthog.opt_out_capturing(); setBanner(false); });
    });
  })();
</script>

<style>
  .cookie-banner {
    position: fixed; z-index: 200; right: 20px; bottom: 20px; left: auto;
    width: min(384px, calc(100vw - 32px));
    display: flex; flex-direction: column; gap: 11px;
    background: color-mix(in srgb, var(--field-1) 90%, transparent);
    -webkit-backdrop-filter: blur(14px); backdrop-filter: blur(14px);
    border: 1px solid var(--hairline-strong); border-radius: var(--r-lg);
    padding: 18px; box-shadow: 0 16px 50px rgba(0, 0, 0, .55);
    animation: cookie-in .42s var(--ease) both;
  }
  .cookie-banner[hidden] { display: none; }
  @keyframes cookie-in { from { opacity: 0; transform: translateY(14px); } to { opacity: 1; transform: none; } }

  .cookie-eyebrow { display: flex; align-items: center; gap: 8px; margin: 0; font-size: var(--text-nano); letter-spacing: .16em; text-transform: uppercase; color: var(--ink-3); }
  .cookie-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--magenta); box-shadow: 0 0 8px color-mix(in srgb, var(--magenta) 85%, transparent); flex-shrink: 0; }
  .cookie-text { margin: 0; font-size: var(--text-caption); line-height: 1.6; color: var(--ink-2); }
  .cookie-text a { color: var(--cyan); border-bottom: 1px solid color-mix(in srgb, var(--cyan) 32%, transparent); }
  .cookie-text a:hover { border-bottom-color: var(--cyan); }

  /* Decline and Accept are equal-width / equal-weight: rejecting must be as easy
     as accepting (GDPR/ePrivacy — no dark-pattern nudge). Accept carries the
     magenta brand signal but the same size. */
  .cookie-actions { display: flex; gap: 8px; margin-top: 3px; }
  .cookie-btn { flex: 1; padding: 9px 14px; font-size: var(--text-caption); font-weight: 500; line-height: 1; border-radius: var(--r-md); cursor: pointer; border: 1px solid var(--hairline-strong); background: transparent; color: var(--ink); transition: border-color .14s var(--ease), color .14s var(--ease), background .14s var(--ease), transform .14s var(--ease); }
  .cookie-btn:hover { border-color: color-mix(in srgb, var(--ink) 32%, transparent); transform: translateY(-1px); }
  .cookie-btn:active { transform: translateY(0); }
  .cookie-btn-accept { border-color: color-mix(in srgb, var(--magenta) 55%, transparent); color: var(--magenta); }
  .cookie-btn-accept:hover { border-color: var(--magenta); background: color-mix(in srgb, var(--magenta) 12%, transparent); }
  .cookie-btn:focus-visible { outline: 2px solid var(--magenta); outline-offset: 2px; }

  @media (prefers-reduced-motion: reduce) { .cookie-banner { animation: none; } .cookie-btn:hover { transform: none; } }
</style>
