---
// The mitos brand mark: two overlapping circles (a filled disc dividing into an
// open ring), geometry derived from the golden ratio. Drawn in currentColor so
// it inherits the surrounding text color; the overlap arc is cut in --mark-bg
// (defaults to the page background) to keep the figure/ground read on any
// surface. Decorative by default (aria-hidden) since it sits beside the "mitos"
// wordmark; pass `decorative={false}` plus a `label` for standalone use.
interface Props {
  class?: string;
  decorative?: boolean;
  label?: string;
}
const { class: className, decorative = true, label = 'Mitos' } = Astro.props;
// Unique clip id per instance so multiple marks on one page stay valid HTML.
const uid = 'mitos-mark-' + crypto.randomUUID().slice(0, 8);
---
<svg
  class:list={['mitos-mark', className]}
  viewBox="100 154.508 330.902 214.59"
  xmlns="http://www.w3.org/2000/svg"
  fill="none"
  aria-hidden={decorative ? 'true' : undefined}
  role={decorative ? undefined : 'img'}
  aria-label={decorative ? undefined : label}
>
  {!decorative && <title>{label}</title>}
  <clipPath id={uid}><circle cx="200" cy="261.803" r="100"/></clipPath>
  <circle cx="200" cy="261.803" r="100" fill="currentColor"/>
  <circle cx="323.607" cy="261.803" r="100" stroke="currentColor" stroke-width="14.59"/>
  <g clip-path={`url(#${uid})`}>
    <circle cx="323.607" cy="261.803" r="100" stroke="var(--mark-bg, #000)" stroke-width="14.59"/>
  </g>
</svg>

<style>
  .mitos-mark {
    display: inline-block;
    height: 1.05em;
    width: auto;
    vertical-align: -0.16em;
  }
</style>
