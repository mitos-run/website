---
// GitHub star button. Real count baked at build time (see lib/stars.ts) and
// refreshed live on the client (data-gh-star, handled in Site.astro).
import { formatStars } from '../lib/stars';
interface Props { count: number; class?: string; }
const { count, class: className } = Astro.props;
const REPO = 'https://github.com/mitos-run/mitos';
---
<a
  class:list={['gh-star', className]}
  href={REPO}
  target="_blank"
  rel="noopener"
  data-gh-star
  aria-label={`Star mitos on GitHub, ${count} stars`}
>
  <svg class="gh-star-mark" viewBox="0 0 16 16" width="15" height="15" aria-hidden="true">
    <path fill="currentColor" d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82a7.6 7.6 0 0 1 2-.27c.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8z" />
  </svg>
  <span class="gh-star-glyph" aria-hidden="true">★</span>
  <span class="gh-star-count">{formatStars(count)}</span>
</a>

<style>
  /* Self-contained so the button renders identically wherever it mounts (nav,
     mobile menu, footer). Positional tweaks (margins) live in the consumer. */
  .gh-star { display: inline-flex; align-items: center; gap: 6px; padding: 6px 11px; border: 1px solid var(--hairline-strong); border-radius: 999px; color: var(--ink-2); font-size: 13px; line-height: 1; white-space: nowrap; transition: border-color .14s var(--ease), color .14s var(--ease); }
  .gh-star:hover { color: var(--ink); border-color: color-mix(in srgb, var(--ink) 30%, transparent); }
  .gh-star-mark { flex-shrink: 0; }
  .gh-star-glyph { color: var(--amber); font-size: 12px; }
  .gh-star-count { font-family: var(--mono); font-variant-numeric: tabular-nums; }
</style>
