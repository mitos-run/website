---
// Shared branded footer for both marketing and docs. Honest links only: every
// href points at a real page or a real GitHub resource. Terms / Cookie-policy
// pages and the X handle are intentionally absent until they exist (legal pages
// tracked in issue #25); the Discord invite is live. Never use em or en dashes in copy.
import Mark from './Mark.astro';
import GhStars from './GhStars.astro';

interface Props {
  /** GitHub star count, baked at build time by the caller (lib/stars). */
  stars: number;
}
const { stars } = Astro.props;

const GITHUB = 'https://github.com/mitos-run/mitos';
const DISCORD = 'https://discord.gg/zddgd2pgab';

// Desktop: a static multi-column sitemap. Mobile (<=480px): each group collapses
// into a <details> accordion (links stay in the DOM, so they remain crawlable).
const columns = [
  {
    label: 'Product',
    links: [
      { label: 'How it works', href: '/#how' },
      { label: 'Benchmarks', href: '/benchmarks' },
      { label: 'Pricing', href: '/pricing' },
      { label: 'Alternatives', href: '/alternatives' },
    ],
  },
  {
    label: 'Developers',
    links: [
      { label: 'Docs', href: '/docs' },
      { label: 'Quickstart', href: '/docs/quickstart' },
      { label: 'Architecture', href: '/docs/architecture' },
      { label: 'Security', href: `${GITHUB}/blob/main/SECURITY.md`, external: true },
    ],
  },
  {
    label: 'Company',
    links: [
      { label: 'About', href: '/about' },
      { label: 'Contact', href: '/contact' },
      { label: 'Blog', href: '/blog' },
      { label: 'Changelog', href: `${GITHUB}/releases`, external: true },
    ],
  },
];

// Legal is its own group (rendered with the cookie-settings button inline) so it
// reads as a first-class section per current footer best practice.
const legalLinks = [
  { label: 'Privacy', href: '/privacy' },
  { label: 'Terms', href: '/terms' },
  { label: 'Cookie policy', href: '/cookie-policy' },
  { label: 'License', href: `${GITHUB}/blob/main/LICENSE`, external: true },
];
---

<footer class="footer">
  <div class="container">
    <!-- Brand band: the footer's only "expression". Mark + tagline, with the
         community/social cluster (GitHub, Discord) balanced on the right. -->
    <div class="footer-band">
      <div class="footer-band-lead">
        <a class="brand" href="/"><Mark class="brand-mark" /> Mitos</a>
        <p class="footer-tag">Isolated, forkable computers for your agents.</p>
      </div>
      <nav class="footer-social" aria-label="Mitos on social platforms">
        <a class="social" href={GITHUB} target="_blank" rel="noopener" aria-label="Mitos on GitHub">
          <svg viewBox="0 0 24 24" aria-hidden="true" fill="currentColor"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>
        </a>
        <a class="social" href={DISCORD} target="_blank" rel="noopener" aria-label="Join the Mitos Discord">
          <svg viewBox="0 0 24 24" aria-hidden="true" fill="currentColor"><path d="M20.317 4.3698a19.7913 19.7913 0 00-4.8851-1.5152.0741.0741 0 00-.0785.0371c-.211.3753-.4447.8648-.6083 1.2495-1.8447-.2762-3.68-.2762-5.4868 0-.1636-.3933-.4058-.8742-.6177-1.2495a.077.077 0 00-.0785-.037 19.7363 19.7363 0 00-4.8852 1.515.0699.0699 0 00-.0321.0277C.5334 9.0458-.319 13.5799.0992 18.0578a.0824.0824 0 00.0312.0561c2.0528 1.5076 4.0413 2.4228 5.9929 3.0294a.0777.0777 0 00.0842-.0276c.4616-.6304.8731-1.2952 1.226-1.9942a.076.076 0 00-.0416-.1057c-.6528-.2476-1.2743-.5495-1.8722-.8923a.077.077 0 01-.0076-.1277c.1258-.0943.2517-.1923.3718-.2914a.0743.0743 0 01.0776-.0105c3.9278 1.7933 8.18 1.7933 12.0614 0a.0739.0739 0 01.0785.0095c.1202.099.246.1981.3728.2924a.077.077 0 01-.0066.1276 12.2986 12.2986 0 01-1.873.8914.0766.0766 0 00-.0407.1067c.3604.698.7719 1.3628 1.225 1.9932a.076.076 0 00.0842.0286c1.961-.6067 3.9495-1.5219 6.0023-3.0294a.077.077 0 00.0313-.0552c.5004-5.177-.8382-9.6739-3.5485-13.6604a.061.061 0 00-.0312-.0286zM8.02 15.3312c-1.1825 0-2.1569-1.0857-2.1569-2.419 0-1.3332.9555-2.4189 2.157-2.4189 1.2108 0 2.1757 1.0952 2.1568 2.419 0 1.3332-.9555 2.4189-2.1569 2.4189zm7.9748 0c-1.1825 0-2.1569-1.0857-2.1569-2.419 0-1.3332.9554-2.4189 2.1569-2.4189 1.2108 0 2.1757 1.0952 2.1568 2.419 0 1.3332-.946 2.4189-2.1568 2.4189Z"/></svg>
        </a>
      </nav>
    </div>

    <div class="footer-grid">
      {columns.map((col) => (
        <details class="footer-col" open>
          <summary class="footer-h"><h2>{col.label}</h2></summary>
          <nav aria-label={col.label}>
            {col.links.map((link) => (
              link.external
                ? <a href={link.href} target="_blank" rel="noopener">{link.label}</a>
                : <a href={link.href}>{link.label}</a>
            ))}
          </nav>
        </details>
      ))}

      <details class="footer-col" open>
        <summary class="footer-h"><h2>Legal</h2></summary>
        <nav aria-label="Legal">
          {legalLinks.map((link) => (
            link.external
              ? <a href={link.href} target="_blank" rel="noopener">{link.label}</a>
              : <a href={link.href}>{link.label}</a>
          ))}
        </nav>
      </details>
    </div>

    <div class="footer-bottom">
      <span class="muted mono">© 2026 Mitos · Open source, Apache 2.0</span>
      <div class="footer-bottom-meta">
        <GhStars count={stars} class="footer-stars" />
        <a class="muted footer-top" href="#top">Back to top ↑</a>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer { border-top: 1px solid var(--hairline); padding: 56px 0 32px; background: var(--field-1); margin-top: 40px; }

  /* Brand band */
  .footer-band { display: flex; align-items: flex-start; justify-content: space-between; gap: 24px; padding-bottom: 36px; border-bottom: 1px solid var(--hairline); }
  .footer-band-lead { min-width: 0; }
  .brand { font-weight: 600; font-size: var(--text-title); letter-spacing: -.02em; display: inline-flex; align-items: center; gap: 8px; }
  .brand-mark { height: 18px; width: auto; filter: drop-shadow(0 0 6px color-mix(in srgb, var(--magenta) 60%, transparent)); }
  .footer-tag { margin: 12px 0 0; font-size: var(--text-dense); color: var(--ink-2); max-width: 26em; }

  /* Community / social cluster: borderless icon buttons, minimal to match the
     hairline footer. Hover lifts ink and adds a faint tint, not a hard chip. */
  .footer-social { display: inline-flex; gap: 2px; flex-shrink: 0; }
  .footer-social .social { display: inline-flex; align-items: center; justify-content: center; width: 40px; height: 40px; border-radius: 10px; color: var(--ink-2); transition: color .15s ease, background .15s ease; }
  .footer-social .social:hover { color: var(--ink); background: color-mix(in srgb, var(--ink) 7%, transparent); }
  .footer-social .social svg { width: 20px; height: 20px; display: block; }

  /* Sitemap columns */
  .footer-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 32px; padding: 40px 0; }
  .footer-col { min-width: 0; }
  /* Columns ship open. On desktop they're static, not collapsible: the summary
     is neutralised (no marker, not focusable-as-toggle) so the open state can't
     be changed. Mobile re-enables the disclosure below. */
  .footer-h { list-style: none; cursor: default; margin: 0 0 14px; pointer-events: none; }
  .footer-h::-webkit-details-marker { display: none; }
  .footer-h::marker { content: ''; }
  .footer-h h2 { margin: 0; font-size: var(--text-caption); font-weight: 500; color: var(--ink-2); }
  .footer-col nav a { display: block; color: var(--ink-2); font-size: var(--text-dense); padding: 4px 0; }
  .footer-col nav a:hover { color: var(--ink); }

  /* Bottom row */
  .footer-bottom { padding-top: 24px; border-top: 1px solid var(--hairline); font-size: var(--text-caption); display: flex; align-items: center; justify-content: space-between; gap: 16px; flex-wrap: wrap; }
  .footer-bottom-meta { display: inline-flex; align-items: center; gap: 18px; }
  .footer-top { font-size: var(--text-caption); }
  .footer-top:hover { color: var(--ink); }

  @media (max-width: 900px) {
    .footer-grid { grid-template-columns: 1fr 1fr; row-gap: 28px; }
  }

  /* Mobile: collapse each group into a real accordion. Links remain in the DOM. */
  @media (max-width: 480px) {
    .footer-band { flex-direction: column; gap: 18px; }
    .footer-grid { grid-template-columns: 1fr; gap: 0; padding: 12px 0 24px; }
    .footer-col { border-bottom: 1px solid var(--hairline); }
    .footer-h { pointer-events: auto; cursor: pointer; display: flex; align-items: center; justify-content: space-between; padding: 16px 0; margin: 0; min-height: 44px; }
    .footer-h::after { content: '+'; color: var(--ink-3); font-size: var(--text-title); line-height: 1; }
    .footer-col[open] .footer-h::after { content: '\2212'; } /* minus */
    .footer-col > nav { padding-bottom: 12px; }
    .footer-col nav a { padding: 8px 0; min-height: 44px; }
  }
</style>
